<div class="min-h-screen bg-gray-50">
  <%= render "shared/header" %>

  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="mb-10">
      <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-blue-600">Dashboard</p>
      <h1 class="text-4xl font-bold text-gray-900">계정 상태</h1>
      <p class="mt-3 max-w-2xl text-base text-gray-600">
        현재 계정의 Trial, 구독, 관리자 권한을 한눈에 확인할 수 있습니다.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-semibold text-gray-500">Trial</p>
        <p class="mt-3 text-3xl font-bold text-gray-900"><%= @trial_days_remaining %>일</p>
        <p class="mt-2 text-sm text-gray-600">
          <%= current_user.trial_active? ? "7일 무료 Trial이 활성화되어 있습니다." : "Trial 기간이 종료되었습니다." %>
        </p>
      </div>

      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-semibold text-gray-500">Subscription</p>
        <p class="mt-3 text-3xl font-bold text-gray-900"><%= @subscription_active ? "Active" : "Inactive" %></p>
        <p class="mt-2 text-sm text-gray-600">
          <%= @subscription_active ? "유료 구독이 연결되어 있습니다." : "구독 정보가 없습니다." %>
        </p>
      </div>

      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-semibold text-gray-500">Access</p>
        <p class="mt-3 text-3xl font-bold text-gray-900"><%= @accessible_chapters %>/20</p>
        <p class="mt-2 text-sm text-gray-600">
          현재 계정으로 열람 가능한 문서 수입니다.
        </p>
      </div>
    </div>

    <div class="mt-8 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-semibold uppercase tracking-wide text-gray-500">Role</p>
      <div class="mt-3 flex flex-wrap items-center gap-3">
        <span class="rounded-full bg-blue-50 px-3 py-1 text-sm font-semibold text-blue-700"><%= current_user.role %></span>
        <% if current_user.admin? %>
          <span class="rounded-full bg-emerald-50 px-3 py-1 text-sm font-semibold text-emerald-700">Admin access</span>
        <% elsif current_user.subscribed? %>
          <span class="rounded-full bg-violet-50 px-3 py-1 text-sm font-semibold text-violet-700">Subscriber</span>
        <% elsif current_user.trial_active? %>
          <span class="rounded-full bg-amber-50 px-3 py-1 text-sm font-semibold text-amber-700">Trial</span>
        <% else %>
          <span class="rounded-full bg-gray-100 px-3 py-1 text-sm font-semibold text-gray-700">Guest access</span>
        <% end %>
      </div>
    </div>
  </div>
</div>