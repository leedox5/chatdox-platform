<div class="min-h-screen bg-gray-50">
  <%= render "shared/header" %>

  <div class="flex">
    <aside class="sticky top-14 hidden h-[calc(100vh-56px)] w-72 flex-shrink-0 overflow-y-auto border-r border-gray-200 bg-gray-50 md:block">
      <div class="p-6">
        <div class="mb-6">
          <%= link_to "← 홈", root_path, class: "mb-3 block text-sm text-gray-500 hover:text-blue-600" %>
          <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-400">클로독스 챕터</h2>
        </div>

        <nav class="space-y-2">
          <% @chapters.each do |chapter| %>
            <% is_current = chapter[:id] == @current_chapter[:id] %>

            <% if chapter[:available] && chapter[:accessible] %>
              <%= link_to claudox_chapter_path(chapter[:id]),
                    class: "flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-colors #{
                      is_current ? 'bg-blue-50 font-semibold text-blue-700' : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900'
                    }" do %>
                <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-md text-xs <%= is_current ? 'bg-blue-600 text-white' : 'bg-gray-200 text-gray-500' %>">
                  <%= chapter[:id] %>
                </span>
                <span class="leading-tight"><%= chapter[:title] %></span>
              <% end %>
            <% elsif chapter[:available] %>
              <div class="flex cursor-not-allowed items-center gap-3 rounded-lg px-3 py-2 text-sm opacity-50">
                <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-md bg-gray-100 text-xs text-gray-400">
                  🔒
                </span>
                <span class="leading-tight text-gray-400"><%= chapter[:title] %></span>
              </div>
            <% else %>
              <div class="flex cursor-not-allowed items-center gap-3 rounded-lg px-3 py-2 text-sm opacity-50">
                <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-md bg-gray-100 text-xs text-gray-400">
                  <%= chapter[:id] %>
                </span>
                <span class="leading-tight text-gray-400"><%= chapter[:title] %></span>
                <span class="ml-auto text-xs text-gray-300">예정</span>
              </div>
            <% end %>
          <% end %>
        </nav>
      </div>
    </aside>

    <main class="min-w-0 flex-1 overflow-y-auto bg-white">
      <div class="max-w-3xl px-5 py-10 sm:px-7 sm:py-12">
        <div class="mb-8 border-b border-gray-100 pb-6">
          <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-blue-600">Claudox</p>
          <h1 class="text-3xl font-bold text-gray-900"><%= @current_chapter[:title] %></h1>
          <p class="mt-3 text-sm text-gray-500">최종 업데이트: <%= l(@last_updated_at, format: :long) %></p>
        </div>

        <div class="doc-content max-w-none">
          <%= sanitize(
            @content_html,
            tags: %w[
              h1 h2 h3 h4 h5 h6 p br hr ul ol li pre code blockquote strong em a
              table thead tbody tr th td
            ],
            attributes: %w[href target rel]
          ) %>
        </div>
      </div>
    </main>
  </div>
</div>