<% product_name = @product&.name || "상품" %>
<% content_for :title, "결제 준비 중 - #{product_name}" %>

<div class="min-h-screen bg-slate-50">
  <%= render "shared/header" %>

  <main class="mx-auto flex min-h-[65vh] w-full max-w-3xl items-center px-4 py-16 sm:px-6">
    <section class="w-full rounded-2xl border border-blue-100 bg-white p-8 text-center shadow-sm sm:p-12" aria-labelledby="checkout-status-title">
      <p class="text-sm font-bold uppercase tracking-[0.18em] text-blue-700"><%= product_name %></p>
      <h1 id="checkout-status-title" class="mt-3 break-keep text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">신규 결제를 준비하고 있습니다</h1>
      <p class="mx-auto mt-5 max-w-xl break-keep text-base leading-7 text-slate-600">
        자동 갱신 없는 기간제 선불 라이선스에 맞는 결제 시스템을 준비 중입니다.
        현재 이 화면에서는 결제나 결제 수단 등록을 시작할 수 없습니다.
      </p>
      <%= link_to "#{product_name} 가격과 준비 상태 보기", @product_landing_path,
        class: "mt-8 inline-flex items-center justify-center rounded-xl bg-blue-600 px-6 py-3 text-sm font-bold text-white transition hover:bg-blue-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2" %>
    </section>
  </main>

  <%= render "shared/footer" %>
</div>
