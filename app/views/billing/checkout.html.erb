<% content_for :title, "결제 시작 - Chatdox" %>

<div class="mx-auto max-w-md px-4 py-16">
  <div class="rounded-xl border border-slate-200 bg-white p-8 shadow-sm">
    <h1 class="text-2xl font-bold text-slate-900">Chatdox 월 구독</h1>
    <p class="mt-2 text-slate-600">월 <%= number_to_currency(@amount, unit: "₩", format: "%u%n", precision: 0) %> · 언제든 취소 가능</p>

    <ul class="mt-6 space-y-2 text-sm text-slate-600">
      <li>✅ 전체 커리큘럼 무제한 접근</li>
      <li>✅ 신규 강의 자동 포함</li>
      <li>✅ 커뮤니티 참여</li>
    </ul>

    <div id="payment-widget" class="mt-8"></div>
    <div id="agreement-widget" class="mt-4"></div>

    <button id="pay-button"
      class="mt-6 w-full rounded-lg bg-blue-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-blue-700">
      결제하기
    </button>
  </div>
</div>

<script src="https://js.tosspayments.com/v2/standard"></script>
<script>
  const clientKey = "<%= ENV.fetch('TOSS_CLIENT_KEY', '') %>";
  const customerKey = "user-<%= current_user.id %>";
  const orderId = "<%= @order_id %>";
  const amount = <%= @amount %>;

  console.log('clientKey:', clientKey);
  console.log('orderId:', orderId);
  console.log('amount:', amount);

  if (!clientKey) {
    console.error('TOSS_CLIENT_KEY is empty!');
    document.getElementById("pay-button").disabled = true;
    document.getElementById("pay-button").textContent = '환경설정 오류';
  }

  try {
    const tossPayments = TossPayments(clientKey);
    const widgets = tossPayments.widgets({ customerKey });

    (async () => {
      await widgets.setAmount({ currency: "KRW", value: amount });
      await Promise.all([
        widgets.renderPaymentMethods({ selector: "#payment-widget", variantKey: "DEFAULT" }),
        widgets.renderAgreement({ selector: "#agreement-widget", variantKey: "AGREEMENT" })
      ]);
    })();

    document.getElementById("pay-button").addEventListener("click", async () => {
      await widgets.requestPayment({
        orderId,
        orderName: "Chatdox 월 구독",
        successUrl: "<%= billing_success_url %>",
        failUrl: "<%= billing_cancel_url %>",
        customerEmail: "<%= current_user.email %>",
        customerName: "<%= current_user.email %>"
      });
    });
  } catch (error) {
    console.error('Payment initialization error:', error);
  }
</script>
