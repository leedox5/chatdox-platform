<% content_for :title, "#{@product.name} 기간제 라이선스 선택" %>

<div class="min-h-screen bg-slate-50">
  <%= render "shared/header" %>

  <main class="mx-auto w-full max-w-5xl px-4 py-12 sm:px-6">
    <div class="mb-8">
      <p class="text-sm font-black uppercase tracking-[0.18em] text-blue-700"><%= @product.name %></p>
      <h1 class="mt-2 break-keep text-3xl font-black tracking-tight text-slate-950">기간제 라이선스 선택</h1>
      <p class="mt-3 break-keep text-sm leading-6 text-slate-600">자동 갱신 없이 선택한 기간을 한 번 결제합니다. 금액은 모두 VAT 포함입니다.</p>
    </div>

    <%= form_with url: billing_orders_path, scope: :order, class: "space-y-8" do |form| %>
      <%= form.hidden_field :product_code, value: @product.code %>

      <fieldset>
        <legend class="text-lg font-bold text-slate-900">이용 기간</legend>
        <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <% @offers.each_with_index do |offer, index| %>
            <label class="cursor-pointer rounded-2xl border border-blue-100 bg-white p-5 shadow-sm has-[:checked]:border-blue-600 has-[:checked]:ring-2 has-[:checked]:ring-blue-100">
              <%= form.radio_button :offer_code, offer.code, checked: index.zero?, class: "text-blue-600" %>
              <span class="ml-2 font-bold text-slate-900"><%= offer.duration_months %>개월</span>
              <strong class="mt-4 block text-2xl text-slate-950"><%= number_to_currency(offer.total_amount, unit: "원", format: "%n%u", precision: 0) %></strong>
              <span class="mt-1 block text-xs text-slate-500">공급가 <%= number_with_delimiter(offer.supply_amount) %>원 + VAT <%= number_with_delimiter(offer.vat_amount) %>원</span>
            </label>
          <% end %>
        </div>
      </fieldset>

      <section class="rounded-2xl border border-slate-200 bg-white p-6">
        <h2 class="font-bold text-slate-900">서비스 시작일</h2>
        <% if @existing_license %>
          <% extension_start_on = @existing_license.last_usable_on + 1.day %>
          <p class="mt-3 break-keep text-sm text-slate-600">현재 <%= @product.name %> 기간 뒤인 <strong><%= I18n.l(extension_start_on, locale: :ko, format: :long) %></strong>부터 자동으로 연장됩니다.</p>
          <%= form.hidden_field :requested_start_on, value: extension_start_on %>
        <% else %>
          <p class="mt-2 text-sm text-slate-600">오늘부터 7일 이내에서 선택할 수 있습니다.</p>
          <%= form.date_field :requested_start_on,
            value: @minimum_start_on,
            min: @minimum_start_on,
            max: @maximum_start_on,
            required: true,
            class: "mt-4 rounded-lg border border-slate-300 px-4 py-2" %>
        <% end %>
      </section>

      <div class="flex justify-end">
        <%= form.submit "주문하기", class: "rounded-xl bg-blue-600 px-6 py-3 text-sm font-bold text-white transition hover:bg-blue-700" %>
      </div>
    <% end %>
  </main>

  <%= render "shared/footer" %>
</div>
