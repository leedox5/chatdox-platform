<% content_for :title, "환불 요청 접수" %>

<div class="min-h-screen bg-slate-50">
  <%= render "shared/header" %>
  <main class="mx-auto w-full max-w-3xl px-4 py-12 sm:px-6">
    <p class="text-sm font-black uppercase tracking-[0.18em] text-indigo-700">Refund request</p>
    <h1 class="mt-2 break-keep text-3xl font-black text-slate-950">환불 요청 접수</h1>
    <p class="mt-3 break-keep rounded-xl bg-amber-50 p-4 text-sm leading-6 text-amber-900">이 화면은 환불을 자동 실행하거나 환불 금액을 확정하지 않습니다. 접수 후 운영자가 정책과 이용 상태를 확인합니다.</p>

    <section class="mt-7 rounded-2xl border border-slate-200 bg-white p-6">
      <h2 class="font-bold text-slate-900"><%= @order.order_items.first.product_name %></h2>
      <dl class="mt-4 grid gap-3 text-sm sm:grid-cols-2">
        <div><dt class="text-slate-500">결제액</dt><dd class="mt-1 font-bold"><%= number_with_delimiter(@order.total_amount) %>원</dd></div>
        <div><dt class="text-slate-500">결제일</dt><dd class="mt-1"><%= I18n.l(@order.paid_at.to_date, locale: :ko, format: :long) %></dd></div>
        <div><dt class="text-slate-500">서비스 시작일</dt><dd class="mt-1"><%= I18n.l(@order.requested_start_on, locale: :ko, format: :long) %></dd></div>
        <div><dt class="text-slate-500">License</dt><dd class="mt-1"><%= @order.licenses.first&.effective_status || "없음" %></dd></div>
      </dl>
    </section>

    <%= form_with model: @refund_request, url: billing_order_refund_requests_path(@order.public_id), class: "mt-7 space-y-5 rounded-2xl border border-slate-200 bg-white p-6" do |form| %>
      <div>
        <%= form.label :reason_code, "요청 사유", class: "block font-bold text-slate-900" %>
        <%= form.select :reason_code,
          [["서비스 시작 전", "before_service_start"], ["중복 결제", "duplicate_payment"], ["시스템 오류", "system_error"], ["서비스 문제", "service_issue"], ["기타", "other"]],
          {}, required: true, class: "mt-2 w-full rounded-lg border border-slate-300 px-4 py-3" %>
      </div>
      <div>
        <%= form.label :customer_note, "설명 (1,000자 이내)", class: "block font-bold text-slate-900" %>
        <%= form.text_area :customer_note, maxlength: 1_000, rows: 5, class: "mt-2 w-full rounded-lg border border-slate-300 px-4 py-3" %>
      </div>
      <p class="break-keep text-sm leading-6 text-slate-600">환불 가능 여부와 환불 금액은 서비스 시작일, 이용 내역 및 구매 기간에 따라 달라질 수 있습니다. 접수 후 확인 결과를 안내해 드립니다.</p>
      <%= form.submit "환불 요청 접수", class: "w-full rounded-xl bg-indigo-700 px-6 py-3.5 font-bold text-white hover:bg-indigo-800" %>
    <% end %>
  </main>
  <%= render "shared/footer" %>
</div>
