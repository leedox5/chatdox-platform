<% content_for :title, "환불 요청 상태" %>

<div class="min-h-screen bg-slate-50">
  <%= render "shared/header" %>
  <main class="mx-auto w-full max-w-3xl px-4 py-12 sm:px-6">
    <p class="text-sm font-black uppercase tracking-[0.18em] text-indigo-700">Refund request</p>
    <h1 class="mt-2 break-keep text-3xl font-black text-slate-950">환불 요청 상태</h1>
    <section class="mt-7 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <dl class="grid gap-5 text-sm sm:grid-cols-2">
        <div><dt class="text-slate-500">상품</dt><dd class="mt-1 font-bold"><%= @order.order_items.first.product_name %></dd></div>
        <div><dt class="text-slate-500">접수 상태</dt><dd class="mt-1 font-bold"><%= refund_status_label(@refund_request.status) %></dd></div>
        <div><dt class="text-slate-500">전액 요청 기준액</dt><dd class="mt-1"><%= number_with_delimiter(@refund_request.requested_amount) %>원</dd></div>
        <div><dt class="text-slate-500">사유</dt><dd class="mt-1"><%= @refund_request.reason_code %></dd></div>
      </dl>
      <div class="mt-6 border-t border-slate-100 pt-5">
        <h2 class="font-bold text-slate-900">고객 설명</h2>
        <p class="mt-2 whitespace-pre-wrap break-words text-sm text-slate-600"><%= @refund_request.customer_note.presence || "설명 없음" %></p>
      </div>
      <% if @refund_request.public_response.present? %>
        <div class="mt-5 rounded-xl bg-indigo-50 p-4">
          <h2 class="font-bold text-indigo-950">운영자 안내</h2>
          <p class="mt-2 whitespace-pre-wrap break-words text-sm text-indigo-900"><%= @refund_request.public_response %></p>
        </div>
      <% end %>
    </section>
    <p class="mt-5 break-keep text-sm leading-6 text-slate-600">승인 표시는 실제 PG 환불 완료가 아닙니다. 실제 처리 결과는 별도 확인 후 안내됩니다.</p>
  </main>
  <%= render "shared/footer" %>
</div>
