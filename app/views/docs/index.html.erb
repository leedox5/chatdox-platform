<div class="min-h-screen bg-gray-50">
  <%= render "shared/header" %>

  <div class="mx-auto max-w-4xl px-4 py-16">
    <div class="mb-12">
      <div class="mb-2 text-sm font-semibold uppercase tracking-wide text-blue-600">문서</div>
      <h1 class="mb-4 text-4xl font-bold text-gray-900">완전한 커리큘럼</h1>
      <p class="text-lg text-gray-500">
        기초부터 배포와 운영까지, 실제 서비스 구축 순서대로 구성되어 있습니다.
      </p>
    </div>

    <div class="space-y-4">
      <% @chapters.each do |chapter| %>
        <% if chapter[:available] %>
          <%= link_to doc_path(chapter[:id]),
                class: "group block rounded-xl border border-gray-200 bg-white p-5 transition-all hover:border-blue-200 hover:shadow-md" do %>
            <div class="flex items-center gap-3">
              <span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-blue-50 text-sm font-bold text-blue-600 group-hover:bg-blue-100">
                <%= chapter[:id] %>
              </span>

              <span class="font-medium text-gray-900 group-hover:text-blue-600"><%= chapter[:title] %></span>

              <span class="ml-auto text-gray-300 group-hover:text-blue-400">→</span>
            </div>
          <% end %>
        <% else %>
          <div class="block cursor-not-allowed rounded-xl border border-gray-100 bg-gray-50 p-5 opacity-50">
            <div class="flex items-center gap-3">
              <span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-gray-100 text-sm font-bold text-gray-400">
                <%= chapter[:id] %>
              </span>

              <span class="font-medium text-gray-400"><%= chapter[:title] %></span>

              <span class="ml-auto text-xs text-gray-300">공개 예정</span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
