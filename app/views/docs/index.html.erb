<div class="min-h-screen bg-gray-50">
  <%= render "shared/header" %>

  <div class="mx-auto max-w-4xl px-4 py-16">
    <div class="mb-12">
      <div class="mb-2 text-sm font-semibold uppercase tracking-wide text-blue-600">문서</div>
      <h1 class="mb-4 text-4xl font-bold text-gray-900">완전한 커리큘럼</h1>
      <p class="text-lg text-gray-500">
        기초부터 배포와 운영까지, 실제 서비스 구축 순서대로 구성되어 있습니다.
      </p>
    </div>

    <div class="space-y-4">
      <% @phase_chapters.each_with_index do |phase, index| %>
        <details class="group overflow-hidden rounded-2xl border border-gray-200 bg-white" <%= "open" if index.zero? %>>
          <summary class="flex cursor-pointer list-none items-center gap-4 px-5 py-4 hover:bg-gray-50">
            <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-blue-50 text-sm font-bold text-blue-600">
              <%= phase[:label].split.last %>
            </div>

            <div class="min-w-0 flex-1">
              <p class="text-xs font-semibold uppercase tracking-wide text-blue-600"><%= phase[:label] %></p>
              <h2 class="text-lg font-semibold text-gray-900"><%= phase[:title] %></h2>
              <p class="text-sm text-gray-500"><%= phase[:description] %></p>
            </div>

            <div class="text-right">
              <p class="text-xs text-gray-400">진행도</p>
              <p class="text-sm font-semibold text-gray-700"><%= phase[:available_count] %>/<%= phase[:total_count] %></p>
            </div>

            <span class="text-gray-400 transition-transform group-open:rotate-180">⌄</span>
          </summary>

          <div class="space-y-3 border-t border-gray-100 bg-gray-50 px-4 py-4 sm:px-5">
            <% phase[:chapters].each do |chapter| %>
              <% if chapter[:available] && chapter[:accessible] %>
                <%= link_to doc_path(chapter[:id]),
                      class: "group block rounded-xl border border-gray-200 bg-white p-4 transition-all hover:border-blue-200 hover:shadow-sm" do %>
                  <div class="flex items-center gap-3">
                    <span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-blue-50 text-sm font-bold text-blue-600 group-hover:bg-blue-100">
                      <%= chapter[:id] %>
                    </span>

                    <span class="font-medium text-gray-900 group-hover:text-blue-600"><%= chapter[:title] %></span>

                    <span class="ml-auto text-gray-300 group-hover:text-blue-400">→</span>
                  </div>
                <% end %>
              <% elsif chapter[:available] %>
                <div class="block cursor-not-allowed rounded-xl border border-gray-100 bg-gray-100 p-4 opacity-60">
                  <div class="flex items-center gap-3">
                    <span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-gray-200 text-sm font-bold text-gray-400">
                      🔒
                    </span>

                    <span class="font-medium text-gray-500"><%= chapter[:title] %></span>

                    <span class="ml-auto text-xs text-gray-400">잠금</span>
                  </div>
                </div>
              <% else %>
                <div class="block cursor-not-allowed rounded-xl border border-gray-100 bg-gray-100 p-4 opacity-60">
                  <div class="flex items-center gap-3">
                    <span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-gray-200 text-sm font-bold text-gray-400">
                      <%= chapter[:id] %>
                    </span>

                    <span class="font-medium text-gray-500"><%= chapter[:title] %></span>

                    <span class="ml-auto text-xs text-gray-400">공개 예정</span>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        </details>
      <% end %>
    </div>
  </div>
</div>
