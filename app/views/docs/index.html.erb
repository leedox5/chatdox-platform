<div class="min-h-screen bg-gray-50">
  <%= render "shared/header" %>

  <div class="mx-auto max-w-4xl px-4 py-16">
    <div class="mb-12">
      <div class="mb-2 text-sm font-semibold uppercase tracking-wide text-blue-600">문서</div>
      <h1 class="mb-4 text-4xl font-bold text-gray-900">완전한 커리큘럼</h1>
      <p class="text-lg text-gray-500">
        기초부터 배포와 운영까지, 실제 서비스 구축 순서대로 구성되어 있습니다.
      </p>
    </div>

    <div class="space-y-4">
      <% @chapters.each_with_index do |chapter, index| %>
        <%= link_to doc_path(chapter[:id]),
              class: "group block rounded-xl border border-gray-200 bg-white p-6 transition-all hover:border-blue-200 hover:shadow-md" do %>
          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-blue-50 text-sm font-bold text-blue-600 group-hover:bg-blue-100">
              <%= format("%02d", index + 1) %>
            </div>

            <div>
              <h2 class="mb-1 text-lg font-semibold text-gray-900 group-hover:text-blue-600"><%= chapter[:title] %></h2>
              <p class="text-sm text-gray-500"><%= chapter[:subtitle] %></p>
            </div>

            <div class="ml-auto text-xl text-gray-300 group-hover:text-blue-400">→</div>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="mt-8 rounded-xl border border-blue-100 bg-blue-50 p-6">
      <p class="text-sm font-medium text-blue-700">📌 챕터 05~20은 순차적으로 공개됩니다.</p>
    </div>
  </div>
</div>
