<% content_for :title, "마이페이지 - Chatdox" %>

<div class="min-h-screen bg-gray-50">
  <%= render "shared/header" %>

  <main class="mx-auto max-w-5xl px-4 py-10 sm:px-6 lg:px-8">
    <header class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-blue-600">My Page</p>
        <h1 class="mt-1 text-3xl font-bold text-gray-900">마이페이지</h1>
        <p class="mt-2 text-gray-600">계정 정보와 상품별 라이선스·주문 내역을 확인하세요.</p>
      </div>

      <%= link_to "내 정보 수정",
        edit_user_registration_path,
        class: "rounded-lg bg-blue-600 px-4 py-2.5 text-center font-semibold text-white transition hover:bg-blue-700" %>
    </header>

    <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
      <div class="flex items-center justify-between gap-3">
        <h2 class="text-lg font-bold text-gray-900">계정 정보</h2>
        <%= link_to "학습 진도는 대시보드에서 →",
          dashboard_path,
          class: "text-sm font-semibold text-blue-600 hover:text-blue-700" %>
      </div>
      <dl class="mt-5 divide-y divide-gray-100 text-sm">
        <div class="flex flex-col gap-1 py-3 sm:flex-row sm:justify-between">
          <dt class="font-medium text-gray-500">이름</dt>
          <dd class="text-gray-900"><%= current_user.name %></dd>
        </div>
        <div class="flex flex-col gap-1 py-3 sm:flex-row sm:justify-between">
          <dt class="font-medium text-gray-500">이메일</dt>
          <dd class="text-gray-900"><%= current_user.email %></dd>
        </div>
        <div class="flex flex-col gap-1 py-3 sm:flex-row sm:justify-between">
          <dt class="font-medium text-gray-500">계정 유형</dt>
          <dd class="text-gray-900"><%= current_user.admin? ? "관리자" : "일반 사용자" %></dd>
        </div>
        <div class="flex flex-col gap-1 py-3 sm:flex-row sm:justify-between">
          <dt class="font-medium text-gray-500">가입일</dt>
          <dd class="text-gray-900"><%= I18n.l(current_user.created_at.to_date, format: :long, locale: :ko) %></dd>
        </div>
      </dl>
    </article>

    <%= render "shared/commerce_summary", licenses: @licenses, orders: @orders %>
  </main>
</div>
