<% content_for :title, "마이페이지 - Chatdox" %>

<div class="min-h-screen bg-gray-50">
  <%= render "shared/header" %>

  <main class="mx-auto max-w-5xl px-4 py-10 sm:px-6 lg:px-8">
    <header class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-blue-600">My Page</p>
        <h1 class="mt-1 text-3xl font-bold text-gray-900">마이페이지</h1>
        <p class="mt-2 text-gray-600">계정 정보와 상품별 이용 상태를 확인하고 필요한 정보를 수정하세요.</p>
      </div>

      <%= link_to "내 정보 수정",
        edit_user_registration_path,
        class: "rounded-lg bg-blue-600 px-4 py-2.5 text-center font-semibold text-white transition hover:bg-blue-700" %>
    </header>

    <section class="grid gap-5 md:grid-cols-3">
      <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm md:col-span-2">
        <h2 class="text-lg font-bold text-gray-900">계정 정보</h2>
        <dl class="mt-5 divide-y divide-gray-100 text-sm">
          <div class="flex flex-col gap-1 py-3 sm:flex-row sm:justify-between">
            <dt class="font-medium text-gray-500">이름</dt>
            <dd class="text-gray-900"><%= current_user.name %></dd>
          </div>
          <div class="flex flex-col gap-1 py-3 sm:flex-row sm:justify-between">
            <dt class="font-medium text-gray-500">이메일</dt>
            <dd class="text-gray-900"><%= current_user.email %></dd>
          </div>
          <div class="flex flex-col gap-1 py-3 sm:flex-row sm:justify-between">
            <dt class="font-medium text-gray-500">계정 유형</dt>
            <dd class="text-gray-900"><%= current_user.admin? ? "관리자" : "일반 사용자" %></dd>
          </div>
          <div class="flex flex-col gap-1 py-3 sm:flex-row sm:justify-between">
            <dt class="font-medium text-gray-500">가입일</dt>
            <dd class="text-gray-900"><%= I18n.l(current_user.created_at.to_date, format: :long, locale: :ko) %></dd>
          </div>
        </dl>
      </article>

      <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
        <div class="flex items-center justify-between gap-3">
          <h2 class="font-semibold text-gray-900">이용 상태</h2>
          <%= subscription_badge(current_user) %>
        </div>
        <p class="mt-5 text-sm text-gray-600"><%= subscription_period_text(current_user) %></p>
        <% unless current_user.licensed_for?("chatdox") || current_user.admin? %>
          <%= link_to "판매 준비 상태 보기",
            chatdox_path(anchor: "pricing"),
            class: "mt-4 inline-block text-sm font-semibold text-blue-600 hover:text-blue-700" %>
        <% end %>
      </article>
    </section>

    <%= render "shared/commerce_summary", licenses: @licenses, orders: @orders %>

    <section class="mt-6 rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-bold text-gray-900">학습 요약</h2>
      <div class="mt-5 grid gap-4 sm:grid-cols-3">
        <div>
          <p class="text-sm font-medium text-gray-500">완료한 챕터</p>
          <p class="mt-2 text-2xl font-bold text-gray-900"><%= @completed_count %>/<%= @total_chapters %></p>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-500">Trial 남은 기간</p>
          <p class="mt-2 text-2xl font-bold text-gray-900"><%= current_user.trial_days_remaining %>일</p>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-500">문서 접근</p>
          <%= link_to "문서 보기", docs_path, class: "mt-2 inline-block font-semibold text-blue-600 hover:text-blue-700" %>
        </div>
      </div>
    </section>
  </main>
</div>
