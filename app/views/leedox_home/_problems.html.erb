<section class="border-y border-slate-200 bg-slate-950 py-20 text-white sm:py-24">
  <div class="mx-auto w-full max-w-6xl px-4 sm:px-6">
    <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-indigo-300">The missing context</p>
        <h2 class="mt-4 break-keep text-3xl font-black tracking-tight sm:text-4xl">AI는 써 봤는데,<br>함께 일하고 있지는 않다면</h2>
      </div>
      <ul class="grid gap-4 sm:grid-cols-3">
        <% [
          ["01", "질문은 많이 하지만", "맥락이 이어지지 않는다."],
          ["02", "튜토리얼은 보지만", "나의 결과물이 완성되지 않는다."],
          ["03", "팀에 도입하고 싶지만", "역할과 규칙이 없다."]
        ].each do |number, lead, point| %>
          <li class="rounded-2xl border border-slate-700 bg-slate-900 p-5">
            <span class="font-mono text-xs font-bold text-indigo-300"><%= number %></span>
            <p class="mt-8 text-sm leading-6 text-slate-400"><%= lead %></p>
            <p class="mt-1 break-keep font-bold leading-6 text-white"><%= point %></p>
          </li>
        <% end %>
      </ul>
    </div>
    <p class="mt-10 border-l-2 border-indigo-400 pl-5 text-lg font-semibold text-slate-200">LEEDOX는 결과와 과정이 함께 남는 AI 협업을 다룹니다.</p>
  </div>
</section>
