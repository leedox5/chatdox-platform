<section class="bg-white py-20 sm:py-28">
  <div class="mx-auto w-full max-w-6xl px-4 sm:px-6">
    <div class="grid gap-12 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
      <div class="lg:sticky lg:top-28">
        <p class="text-sm font-black uppercase tracking-[0.18em] text-indigo-700">Inside the work</p>
        <h2 class="mt-3 break-keep text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">결과만 보여주지 않습니다</h2>
        <div class="mt-7 grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
          <% ["실제 프로젝트에서 출발", "판단과 시행착오까지 기록", "따라 하거나 적용할 수 있는 구조", "인간과 AI의 역할을 함께 설명"].each do |item| %>
            <p class="flex items-center gap-3 text-sm font-semibold text-slate-700"><span class="flex h-6 w-6 items-center justify-center rounded-full bg-indigo-50 text-xs text-indigo-700">✓</span><%= item %></p>
          <% end %>
        </div>
      </div>

      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-slate-950 shadow-2xl shadow-slate-900/10">
        <div class="flex items-center gap-2 border-b border-slate-800 px-5 py-4">
          <span class="h-2.5 w-2.5 rounded-full bg-rose-400"></span><span class="h-2.5 w-2.5 rounded-full bg-amber-300"></span><span class="h-2.5 w-2.5 rounded-full bg-emerald-400"></span>
          <span class="ml-3 font-mono text-xs text-slate-500">leedox / actual-records</span>
        </div>
        <div class="grid md:grid-cols-2">
          <article class="border-b border-slate-800 p-6 md:border-b-0 md:border-r">
            <p class="font-mono text-xs font-bold text-blue-400">CHATDOX / BUILD LOG</p>
            <h3 class="mt-3 break-keep font-bold text-white">실제 SaaS 구축 목차</h3>
            <ol class="mt-6 space-y-4 font-mono text-sm text-slate-400">
              <% Curriculum.all.first(4).each do |chapter| %>
                <li class="flex gap-3"><span class="text-blue-400"><%= chapter[:id] %></span><span><%= chapter[:title] %></span></li>
              <% end %>
            </ol>
            <%= link_to "구축 문서 보기 →", docs_path, class: "mt-7 inline-block rounded text-sm font-bold text-blue-300 hover:text-blue-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-400" %>
          </article>
          <article class="p-6">
            <p class="font-mono text-xs font-bold text-violet-400">CLAUDOX / TEAM LOG</p>
            <h3 class="mt-3 break-keep font-bold text-white">실제 협업 기록 목차</h3>
            <ol class="mt-6 space-y-4 font-mono text-sm text-slate-400">
              <% [["01", "클로독스와의 첫만남"], ["03", "팀에 합류하다"], ["05", "기억을 심다 — 메모리와 CLAUDE.md"], ["10", "코드 리뷰를 맡기다"]].each do |id, title| %>
                <li class="flex gap-3"><span class="text-violet-400"><%= id %></span><span><%= title %></span></li>
              <% end %>
            </ol>
            <%= link_to "협업 기록 보기 →", claudox_path, class: "mt-7 inline-block rounded text-sm font-bold text-violet-300 hover:text-violet-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-violet-400" %>
          </article>
        </div>
      </div>
    </div>
  </div>
</section>
