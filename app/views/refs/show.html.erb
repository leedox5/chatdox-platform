<% content_for :title, @current_ref[:title] %>

<div class="min-h-screen bg-white">
  <%= render "shared/header" %>

  <div class="flex">
    <aside class="sticky top-14 hidden h-[calc(100vh-56px)] w-64 flex-shrink-0 overflow-y-auto border-r border-gray-200 bg-gray-50 md:block">
      <div class="p-6">
        <div class="mb-6">
          <%= link_to "← 참조 문서", refs_path, class: "mb-3 block text-sm text-gray-500 hover:text-blue-600" %>
          <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-400">참조</h2>
        </div>

        <nav class="space-y-2">
          <% @phase_refs.each do |phase| %>
            <% current_in_phase = phase[:references].any? { |reference| reference[:id] == @current_ref[:id] } %>

            <details class="group overflow-hidden rounded-xl border border-gray-200 bg-white" <%= "open" if current_in_phase %>>
              <summary class="flex cursor-pointer list-none items-center gap-2 px-3 py-2 hover:bg-gray-50">
                <div class="min-w-0 flex-1">
                  <p class="text-[11px] font-semibold uppercase tracking-wide text-blue-600"><%= phase[:label] %></p>
                  <p class="truncate text-sm font-medium text-gray-800"><%= phase[:title] %></p>
                </div>

                <span class="text-xs font-semibold text-gray-500"><%= phase[:available_count] %>/<%= phase[:total_count] %></span>
                <span class="text-xs text-gray-400 transition-transform group-open:rotate-180">⌄</span>
              </summary>

              <div class="space-y-1 border-t border-gray-100 p-2">
                <% phase[:references].each do |reference| %>
                  <% is_current = reference[:id] == @current_ref[:id] %>

                  <% if reference[:available] %>
                    <%= link_to ref_path(reference[:id]),
                          class: "flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-colors #{
                            is_current ? 'bg-blue-50 font-semibold text-blue-700' : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900'
                          }" do %>
                      <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-md text-xs <%= is_current ? 'bg-blue-600 text-white' : 'bg-gray-200 text-gray-500' %>">
                        <%= reference[:chapter_id] %>
                      </span>
                      <span class="leading-tight"><%= reference[:title] %></span>
                    <% end %>
                  <% else %>
                    <div class="flex cursor-not-allowed items-center gap-3 rounded-lg px-3 py-2 text-sm opacity-60">
                      <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-md bg-gray-100 text-xs text-gray-400">
                        <%= reference[:chapter_id] %>
                      </span>
                      <span class="leading-tight text-gray-400"><%= reference[:title] %></span>
                    </div>
                  <% end %>
                <% end %>
              </div>
            </details>
          <% end %>
        </nav>
      </div>
    </aside>

    <main class="min-w-0 flex-1 overflow-y-auto">
      <div class="max-w-3xl px-5 py-10 sm:px-7 sm:py-12">
        <div class="mb-8 border-b border-gray-100 pb-6">
          <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-blue-600">Chapter <%= @current_ref[:chapter_id] %> Reference</p>
          <h1 class="text-3xl font-bold text-gray-900"><%= @current_ref[:title] %></h1>
          <% if @current_ref[:chapter] %>
            <p class="mt-2 text-sm text-gray-500"><%= @current_ref[:chapter][:title] %></p>
          <% end %>
        </div>

        <div class="doc-content max-w-none">
          <%= @content_html %>
        </div>

        <div class="mt-16 flex justify-between border-t border-gray-100 pt-8">
          <% if @prev_ref %>
            <%= link_to ref_path(@prev_ref[:id]), class: "flex items-center gap-2 text-sm text-gray-500 hover:text-blue-600" do %>
              <span>←</span>
              <span><%= @prev_ref[:title] %></span>
            <% end %>
          <% else %>
            <div></div>
          <% end %>

          <% if @next_ref %>
            <%= link_to ref_path(@next_ref[:id]), class: "flex items-center gap-2 text-sm text-gray-500 hover:text-blue-600" do %>
              <span><%= @next_ref[:title] %></span>
              <span>→</span>
            <% end %>
          <% end %>
        </div>
      </div>
    </main>
  </div>
</div>
