<header class="sticky top-0 z-50 border-b border-slate-200/70 bg-white/90 shadow-sm backdrop-blur">
  <div class="mx-auto flex w-full max-w-6xl items-center justify-between px-4 py-3 sm:px-6">
    <%= link_to root_path, class: "inline-flex items-center gap-2 text-lg font-semibold tracking-tight text-slate-900" do %>
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-blue-600 text-sm font-bold text-white">C</span>
      채독스
    <% end %>

    <nav class="hidden items-center gap-6 text-sm font-medium text-slate-600 md:flex">
      <% primary_navigation_items.each do |label, path| %>
        <%= link_to label, path, class: "transition hover:text-slate-900" %>
      <% end %>

      <% if user_signed_in? %>
        <span class="max-w-48 truncate text-slate-500"><%= current_user.email %></span>
        <%= link_to "로그아웃",
          destroy_user_session_path,
          data: { turbo_method: :delete },
          class: "rounded-lg border border-red-200 px-4 py-2 text-red-600 transition hover:border-red-300 hover:bg-red-50" %>
      <% else %>
        <%= link_to "로그인",
          new_user_session_path,
          class: "rounded-lg border border-slate-200 px-4 py-2 text-slate-700 transition hover:border-slate-300 hover:text-slate-900" %>
        <%= link_to "회원가입",
          new_user_registration_path,
          class: "rounded-lg bg-blue-600 px-4 py-2 font-semibold text-white transition hover:bg-blue-700" %>
      <% end %>
    </nav>

    <% if user_signed_in? %>
      <% mobile_navigation_items.each do |label, path| %>
        <%= link_to label,
          path,
          class: "mr-2 rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:bg-slate-50 md:hidden" %>
      <% end %>
      <%= link_to "로그아웃",
        destroy_user_session_path,
        data: { turbo_method: :delete },
        class: "rounded-lg border border-red-200 px-4 py-2 text-sm font-semibold text-red-600 transition hover:bg-red-50 md:hidden" %>
    <% else %>
      <%= link_to "로그인",
        new_user_session_path,
        class: "mr-2 rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:bg-slate-50 md:hidden" %>
      <%= link_to "회원가입",
        new_user_registration_path,
        class: "rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-blue-700 md:hidden" %>
    <% end %>
  </div>
</header>
