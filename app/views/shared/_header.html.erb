<header class="sticky top-0 z-50 border-b border-slate-200/70 bg-white/90 shadow-sm backdrop-blur">
  <div class="mx-auto flex w-full max-w-6xl items-center justify-between px-4 py-3 sm:px-6">
    <%= link_to root_path, class: "inline-flex items-center gap-2 text-lg font-semibold tracking-tight text-slate-900" do %>
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-blue-600 text-sm font-bold text-white">C</span>
      채독스
    <% end %>

    <nav class="hidden items-center gap-6 text-sm font-medium text-slate-600 md:flex">
      <%= link_to "시작", getting_started_path, class: "transition hover:text-slate-900" %>
      <%= link_to "가격", pricing_path, class: "transition hover:text-slate-900" %>
      <%= link_to "문서", docs_path, class: "transition hover:text-slate-900" %>
      <%= link_to "커뮤니티", community_path, class: "transition hover:text-slate-900" %>
      <%= link_to "로그인", login_path, class: "rounded-lg border border-slate-200 px-4 py-2 text-slate-700 transition hover:border-slate-300 hover:text-slate-900" %>
    </nav>

    <%= link_to "시작", getting_started_path, class: "rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-blue-700 md:hidden" %>
  </div>
</header>
