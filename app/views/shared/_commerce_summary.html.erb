<section aria-label="상품별 라이선스" class="mt-6 rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h2 class="text-lg font-bold text-gray-900">상품별 라이선스</h2>
    <% if Commerce::Sales.enabled_for_code?("chatdox") && Payments::Configuration.current.checkout_ready? %>
      <%= link_to "Chatdox 구매", billing_checkout_path, class: "text-sm font-semibold text-blue-600 hover:text-blue-700" %>
    <% else %>
      <span class="text-sm font-semibold text-slate-500">신규 판매 준비 중</span>
    <% end %>
  </div>

  <% if licenses.any? %>
    <div class="mt-5 grid gap-4 md:grid-cols-2">
      <% licenses.each do |license| %>
        <article class="rounded-xl border border-slate-200 bg-slate-50 p-5">
          <div class="flex items-center justify-between gap-3">
            <h3 class="font-bold text-slate-900"><%= license.product.name %></h3>
            <span class="rounded-full bg-white px-3 py-1 text-xs font-bold text-slate-700"><%= { "active" => "이용 중", "scheduled" => "이용 예정", "expired" => "만료", "canceled" => "취소" }.fetch(license.effective_status) %></span>
          </div>
          <p class="mt-3 text-sm text-slate-600"><%= I18n.l(license.starts_on, locale: :ko, format: :long) %> ~ <%= I18n.l(license.last_usable_on, locale: :ko, format: :long) %></p>
        </article>
      <% end %>
    </div>
  <% else %>
    <p class="mt-4 rounded-lg bg-slate-50 p-5 text-sm text-slate-600">아직 상품별 라이선스가 없습니다.</p>
  <% end %>

  <% if orders.any? %>
    <div class="mt-7 border-t border-slate-100 pt-5">
      <h3 class="font-bold text-slate-900">최근 주문</h3>
      <ul class="mt-3 divide-y divide-slate-100 text-sm">
        <% orders.each do |order| %>
          <li class="py-3">
            <div class="flex flex-wrap items-center justify-between gap-2">
              <span class="text-slate-700"><%= order.order_items.first&.product_name || "상품" %> · <%= number_with_delimiter(order.total_amount) %>원</span>
              <div class="flex flex-wrap items-center gap-3">
                <span class="font-semibold text-slate-600"><%= { "pending" => "결제 대기", "paid" => "결제 완료", "failed" => "결제 실패", "canceled" => "취소", "abandoned" => "결제 이탈" }.fetch(order.status) %></span>
                <% open_refund = order.refund_requests.find(&:open?) %>
                <% if open_refund %>
                  <%= link_to "환불 요청 확인", refund_request_path(open_refund.public_id), class: "font-semibold text-indigo-700 hover:underline" %>
                <% elsif order.status == "paid" %>
                  <%= link_to "환불 요청", new_billing_order_refund_request_path(order.public_id), class: "font-semibold text-indigo-700 hover:underline" %>
                <% elsif (order.status == "abandoned" || (order.status == "pending" && Commerce::PendingOrderAssessment.call(order: order).safe_to_abandon)) && Commerce::Sales.enabled_for_code?("chatdox") && Payments::Configuration.current.checkout_ready? %>
                  <%= link_to "새 주문으로 재시도", retry_billing_order_path(order.public_id), class: "font-semibold text-blue-700 hover:underline" %>
                <% end %>
              </div>
            </div>
            <% if order.status == "pending" %>
              <p class="mt-1 text-xs text-slate-500">결제가 완료되지 않은 주문입니다.</p>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</section>
