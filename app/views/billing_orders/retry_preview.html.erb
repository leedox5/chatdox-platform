<% content_for :title, "Chatdox 결제 재시도" %>

<div class="min-h-screen bg-slate-50">
  <%= render "shared/header" %>
  <main class="mx-auto w-full max-w-4xl px-4 py-12 sm:px-6">
    <p class="text-sm font-black uppercase tracking-[0.18em] text-blue-700">Payment retry</p>
    <h1 class="mt-2 break-keep text-3xl font-black text-slate-950">현재 상품 조건으로 새 주문을 만듭니다</h1>
    <p class="mt-3 break-keep text-sm leading-6 text-slate-600">이전 주문은 보존되며 다시 결제하지 않습니다. 아래 현재 가격과 기간을 확인한 뒤 새 pending 주문을 생성합니다.</p>

    <div class="mt-8 grid gap-5 md:grid-cols-2">
      <section class="rounded-2xl border border-slate-200 bg-white p-6" aria-labelledby="previous-order-title">
        <h2 id="previous-order-title" class="font-bold text-slate-900">이전 주문 snapshot</h2>
        <dl class="mt-4 space-y-3 text-sm">
          <div class="flex justify-between gap-4"><dt>기간</dt><dd><%= @source_item.duration_months %>개월</dd></div>
          <div class="flex justify-between gap-4"><dt>결제액</dt><dd><%= number_with_delimiter(@source_order.total_amount) %>원</dd></div>
          <div class="flex justify-between gap-4"><dt>상태</dt><dd><%= @source_order.status %></dd></div>
        </dl>
      </section>
      <section class="rounded-2xl border border-blue-200 bg-blue-50 p-6" aria-labelledby="current-offer-title">
        <h2 id="current-offer-title" class="font-bold text-slate-900">현재 Offer</h2>
        <dl class="mt-4 space-y-3 text-sm">
          <div class="flex justify-between gap-4"><dt>기간</dt><dd><%= @current_offer.duration_months %>개월</dd></div>
          <div class="flex justify-between gap-4"><dt>공급가 + VAT</dt><dd><%= number_with_delimiter(@current_offer.supply_amount) %>원 + <%= number_with_delimiter(@current_offer.vat_amount) %>원</dd></div>
          <div class="flex justify-between gap-4 font-bold"><dt>결제액</dt><dd><%= number_with_delimiter(@current_offer.total_amount) %>원</dd></div>
          <div class="flex justify-between gap-4"><dt>새 이용 기간</dt><dd><%= I18n.l(@period.starts_on, locale: :ko, format: :long) %> ~ <%= I18n.l(@period.last_usable_on, locale: :ko, format: :long) %></dd></div>
        </dl>
      </section>
    </div>

    <%= button_to "새 주문 생성", create_retry_billing_order_path(@source_order.public_id),
      class: "mt-8 w-full rounded-xl bg-blue-600 px-6 py-3.5 font-bold text-white hover:bg-blue-700" %>
  </main>
  <%= render "shared/footer" %>
</div>
