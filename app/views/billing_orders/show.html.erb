<% content_for :title, "Chatdox 주문 확인" %>
<% content_for :head do %>
  <script src="https://cdn.portone.io/v2/browser-sdk.js"></script>
<% end %>

<div class="min-h-screen bg-slate-50">
  <%= render "shared/header" %>

  <main class="mx-auto w-full max-w-3xl px-4 py-12 sm:px-6">
    <p class="text-sm font-black uppercase tracking-[0.18em] text-blue-700">Order</p>
    <h1 class="mt-2 break-keep text-3xl font-black tracking-tight text-slate-950">주문 내용을 확인해 주세요</h1>

    <section class="mt-8 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm" aria-labelledby="order-summary-title">
      <h2 id="order-summary-title" class="text-lg font-bold text-slate-900"><%= @order_item.product_name %> 기간제 라이선스</h2>
      <dl class="mt-5 divide-y divide-slate-100 text-sm">
        <div class="flex justify-between gap-4 py-3"><dt class="text-slate-500">이용 기간</dt><dd class="font-semibold"><%= @order_item.duration_months %>개월</dd></div>
        <div class="flex justify-between gap-4 py-3"><dt class="text-slate-500">시작일</dt><dd class="font-semibold"><%= I18n.l(@period.starts_on, locale: :ko, format: :long) %></dd></div>
        <div class="flex justify-between gap-4 py-3"><dt class="text-slate-500">마지막 이용일</dt><dd class="font-semibold"><%= I18n.l(@period.last_usable_on, locale: :ko, format: :long) %></dd></div>
        <div class="flex justify-between gap-4 py-3"><dt class="text-slate-500">공급가</dt><dd><%= number_with_delimiter(@order.supply_amount) %>원</dd></div>
        <div class="flex justify-between gap-4 py-3"><dt class="text-slate-500">VAT</dt><dd><%= number_with_delimiter(@order.vat_amount) %>원</dd></div>
        <div class="flex justify-between gap-4 py-4 text-base"><dt class="font-bold text-slate-900">결제 금액</dt><dd class="font-black text-blue-700"><%= number_with_delimiter(@order.total_amount) %>원</dd></div>
      </dl>
      <p class="mt-4 break-keep rounded-xl bg-slate-50 p-4 text-xs leading-5 text-slate-600">자동 갱신되지 않는 일회성 선불 결제입니다. 결제 금액과 라이선스 기간은 서버에 저장된 주문을 기준으로 다시 검증합니다.</p>
    </section>

    <button id="payment-button" type="button" class="mt-6 w-full rounded-xl bg-blue-600 px-6 py-3.5 font-bold text-white transition hover:bg-blue-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2">
      <%= number_with_delimiter(@order.total_amount) %>원 결제하기
    </button>
    <p id="payment-error" class="mt-3 hidden text-sm font-semibold text-red-700" role="alert"></p>
  </main>

  <%= render "shared/footer" %>
</div>

<script>
  document.getElementById("payment-button")?.addEventListener("click", async (event) => {
    const button = event.currentTarget;
    const error = document.getElementById("payment-error");
    button.disabled = true;
    error.classList.add("hidden");

    try {
      const response = await PortOne.requestPayment({
        storeId: <%= raw json_escape(@portone_store_id.to_json) %>,
        channelKey: <%= raw json_escape(@portone_channel_key.to_json) %>,
        paymentId: <%= raw json_escape(@order.public_id.to_json) %>,
        orderName: <%= raw json_escape("#{@order_item.product_name} #{@order_item.duration_months}개월".to_json) %>,
        totalAmount: <%= @order.total_amount %>,
        currency: <%= raw json_escape(@order.currency.to_json) %>,
        payMethod: "CARD",
        customer: { email: <%= raw json_escape(current_user.email.to_json) %> },
        redirectUrl: <%= raw json_escape(billing_success_url.to_json) %>
      });
      if (response.code) throw new Error(response.message || "결제가 취소되었습니다.");
      window.location.href = <%= raw json_escape(billing_success_url.to_json) %> + "?paymentId=" + encodeURIComponent(response.paymentId);
    } catch (paymentError) {
      error.textContent = paymentError.message || "결제를 시작하지 못했습니다.";
      error.classList.remove("hidden");
      button.disabled = false;
    }
  });
</script>
