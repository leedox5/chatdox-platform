<% content_for :title, "GitHub Lab 연결 - LEEDOX" %>

<div class="min-h-screen bg-slate-50">
  <%= render "shared/header" %>
  <main class="mx-auto max-w-4xl px-4 py-10 sm:px-6 lg:px-8">
    <header>
      <p class="text-sm font-bold uppercase tracking-[0.2em] text-indigo-700">GitHub Lab Access</p>
      <h1 class="mt-2 break-keep text-3xl font-black text-slate-950">Chatdox GitHub 계정 연결</h1>
      <p class="mt-3 text-slate-600">Private Lab 초대와 라이선스 만료 후 원격 접근 회수를 위해 GitHub 사용자명만 수집합니다.</p>
    </header>

    <section class="mt-8 rounded-2xl border border-indigo-100 bg-indigo-50 p-6 text-sm leading-7 text-slate-700">
      <h2 class="font-bold text-slate-950">연결 전 확인</h2>
      <ul class="mt-2 list-disc space-y-1 pl-5">
        <li>Chatdox 라이선스 1개에는 구매자 본인의 GitHub 계정 1개만 연결합니다.</li>
        <li>계정 공유와 양도를 허용하지 않으며, 계정 변경은 기존 권한 회수 후 진행합니다.</li>
        <li>만료 후 Private Lab의 원격 접근과 업데이트는 종료됩니다.</li>
        <li>이미 clone한 로컬 소스는 자동 삭제되지 않으며, 허용된 사용 범위는 계속 적용됩니다.</li>
        <li>최종 개인정보 보유기간은 출시 전 별도 검토하며 연결 해제를 요청할 수 있습니다.</li>
      </ul>
    </section>

    <% if @links.empty? %>
      <section class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-bold text-slate-950">GitHub 사용자명 연결 요청</h2>
        <%= form_with url: github_access_path, scope: :external_account_link, class: "mt-5 space-y-4" do |form| %>
          <div>
            <%= form.label :username, "GitHub 사용자명", class: "block font-semibold text-slate-800" %>
            <%= form.text_field :username, required: true, maxlength: 40, placeholder: "예: octocat", autocomplete: "off",
              class: "mt-2 w-full rounded-lg border border-slate-300 px-3 py-2.5" %>
          </div>
          <%= form.submit "계정 확인 요청", class: "rounded-lg bg-indigo-700 px-4 py-2.5 font-semibold text-white hover:bg-indigo-800" %>
        <% end %>
      </section>
    <% end %>

    <% if @links.any? %>
      <section class="mt-6 space-y-5" aria-label="GitHub 연결 이력">
        <% @links.each do |link| %>
          <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div>
                <p class="text-sm font-semibold text-slate-500">GitHub username</p>
                <h2 class="mt-1 break-all text-xl font-bold text-slate-950">@<%= link.username %></h2>
              </div>
              <span class="rounded-full bg-slate-100 px-3 py-1 text-sm font-semibold text-slate-700"><%= external_link_status_label(link.status) %></span>
            </div>

            <% if link.external_access_grants.any? %>
              <div class="mt-5 space-y-3 border-t border-slate-100 pt-5">
                <% link.external_access_grants.each do |grant| %>
                  <div class="rounded-xl bg-slate-50 p-4">
                    <div class="flex flex-wrap justify-between gap-2">
                      <strong><%= grant.product.name %> Lab</strong>
                      <span class="font-semibold text-indigo-700"><%= external_grant_status_label(grant.status) %></span>
                    </div>
                    <p class="mt-2 text-sm text-slate-600">라이선스: <%= grant.license.starts_on %> ~ <%= grant.license.last_usable_on %></p>
                    <% if grant.public_message.present? %><p class="mt-2 text-sm text-slate-700"><%= grant.public_message %></p><% end %>
                  </div>
                <% end %>
              </div>
            <% else %>
              <p class="mt-5 rounded-xl bg-slate-50 p-4 text-sm text-slate-600">계정 확인과 유효한 Chatdox 라이선스를 확인한 뒤 초대 준비 상태가 표시됩니다.</p>
            <% end %>

            <% if link.status == "verified" && link.replacement_link.blank? %>
              <div class="mt-5 grid gap-4 border-t border-slate-100 pt-5 md:grid-cols-2">
                <%= form_with url: change_github_access_path, scope: :external_account_link, class: "space-y-3" do |form| %>
                  <%= form.hidden_field :link_id, value: link.public_id %>
                  <%= form.label :username, "새 GitHub 사용자명", class: "block text-sm font-semibold text-slate-800" %>
                  <%= form.text_field :username, required: true, maxlength: 40, autocomplete: "off", class: "w-full rounded-lg border border-slate-300 px-3 py-2.5" %>
                  <%= form.submit "계정 변경 요청", class: "rounded-lg border border-indigo-300 px-4 py-2 font-semibold text-indigo-700 hover:bg-indigo-50" %>
                <% end %>
                <div>
                  <p class="text-sm text-slate-600">연결 해제 시 활성 Lab 권한을 먼저 회수하고 완료 후 계정 연결을 닫습니다.</p>
                  <%= button_to "연결 해제 요청", disconnect_github_access_path,
                    params: { external_account_link: { link_id: link.public_id } },
                    class: "mt-3 rounded-lg border border-red-200 px-4 py-2 font-semibold text-red-700 hover:bg-red-50" %>
                </div>
              </div>
            <% end %>
          </article>
        <% end %>
      </section>
    <% end %>
  </main>
</div>
