<% content_for :title, "내 정보 수정 - Chatdox" %>

<div class="min-h-screen bg-gray-50">
  <%= render "shared/header" %>

  <main class="mx-auto max-w-3xl px-4 py-10 sm:px-6 lg:px-8">
    <header class="mb-8">
      <p class="text-sm font-semibold uppercase tracking-wide text-blue-600">Account</p>
      <h1 class="mt-1 text-3xl font-bold text-gray-900">내 정보 수정</h1>
      <p class="mt-2 text-gray-600">이메일 또는 비밀번호를 변경하려면 현재 비밀번호 확인이 필요합니다.</p>
    </header>

    <section class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm sm:p-8">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-6" }) do |form| %>
        <%= render "users/shared/error_messages", resource: resource %>

        <div>
          <%= form.label :email, "이메일", class: "mb-2 block text-sm font-semibold text-gray-700" %>
          <%= form.email_field :email,
            autofocus: true,
            autocomplete: "email",
            class: "w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:border-blue-500 focus:outline-none" %>
        </div>

        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <p class="rounded-lg bg-amber-50 p-4 text-sm text-amber-800">
            새 이메일 확인 대기 중: <%= resource.unconfirmed_email %>
          </p>
        <% end %>

        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <%= form.label :password, "새 비밀번호", class: "mb-2 block text-sm font-semibold text-gray-700" %>
            <%= form.password_field :password,
              autocomplete: "new-password",
              class: "w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:border-blue-500 focus:outline-none" %>
            <p class="mt-2 text-xs text-gray-500">변경하지 않으려면 비워두세요.</p>
          </div>

          <div>
            <%= form.label :password_confirmation, "새 비밀번호 확인", class: "mb-2 block text-sm font-semibold text-gray-700" %>
            <%= form.password_field :password_confirmation,
              autocomplete: "new-password",
              class: "w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:border-blue-500 focus:outline-none" %>
          </div>
        </div>

        <div>
          <%= form.label :current_password, "현재 비밀번호", class: "mb-2 block text-sm font-semibold text-gray-700" %>
          <%= form.password_field :current_password,
            autocomplete: "current-password",
            required: true,
            class: "w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:border-blue-500 focus:outline-none" %>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <%= link_to "← 마이페이지", mypage_path, class: "font-medium text-gray-500 hover:text-blue-600" %>
          <%= form.submit "변경사항 저장",
            class: "rounded-lg bg-blue-600 px-5 py-2.5 font-semibold text-white transition hover:bg-blue-700" %>
        </div>
      <% end %>
    </section>
  </main>
</div>
