<div class="min-h-screen bg-white">
  <%= render "shared/header" %>

  <main class="mx-auto w-full max-w-2xl px-5 py-10 sm:px-7 sm:py-12">
    <%= link_to "← #{@service_desk_request.to_param}로 돌아가기", service_desk_request_path(@service_desk_request), class: "mb-6 inline-block text-sm text-gray-500 hover:text-blue-600" %>

    <h1 class="mb-2 text-3xl font-bold text-gray-900">Job 수정 — <%= @job.job_number.to_s.rjust(4, "0") %></h1>
    <p class="mb-8 text-sm text-gray-500"><%= @job.author %> · <%= l(@job.performed_at, format: :long) %></p>

    <%= form_with model: @job, url: service_desk_request_job_path(@service_desk_request, @job.job_number), method: :patch, class: "space-y-5" do |form| %>
      <% if @job.errors.any? %>
        <div class="rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-700">
          <%= @job.errors.full_messages.to_sentence %>
        </div>
      <% end %>

      <div>
        <%= form.label :content, "내용", class: "mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-400" %>
        <%= form.text_area :content, rows: 6, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
      </div>

      <%= form.submit "저장", class: "inline-flex items-center justify-center rounded-lg bg-blue-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-blue-700" %>
    <% end %>
  </main>
</div>
