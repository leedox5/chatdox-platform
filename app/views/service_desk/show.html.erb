<div class="min-h-screen bg-white">
  <%= render "shared/header" %>

  <main class="mx-auto w-full max-w-3xl px-5 py-10 sm:px-7 sm:py-12">
    <%= link_to "← 서비스데스크 목록", service_desk_path, class: "mb-6 inline-block text-sm text-gray-500 hover:text-blue-600" %>

    <div class="mb-8 border-b border-gray-100 pb-6">
      <div class="flex items-start justify-between gap-4">
        <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-blue-600">Request <%= @current_request.to_param %></p>
        <%= link_to "수정", edit_service_desk_request_path(@current_request), class: "text-sm text-gray-500 hover:text-blue-600" %>
      </div>
      <h1 class="text-3xl font-bold text-gray-900"><%= @current_request.subject %></h1>
      <p class="mt-3 text-sm text-gray-500"><%= l(@current_request.date, format: :service_desk) %> 발행 · 최종 업데이트: <%= l(@current_request.updated_at, format: :service_desk) %></p>
    </div>

    <section class="mb-8 grid gap-4 sm:grid-cols-3">
      <article class="rounded-lg border border-gray-200 bg-gray-50 p-4">
        <p class="text-xs font-semibold uppercase tracking-wide text-gray-400">Requester</p>
        <p class="mt-2 font-medium text-gray-900"><%= @current_request.requester %></p>
      </article>

      <article class="rounded-lg border border-gray-200 bg-gray-50 p-4">
        <p class="text-xs font-semibold uppercase tracking-wide text-gray-400">Status</p>
        <p class="mt-2 font-medium text-gray-900"><%= @current_request.status_label %></p>
      </article>

      <article class="rounded-lg border border-gray-200 bg-gray-50 p-4">
        <p class="text-xs font-semibold uppercase tracking-wide text-gray-400">Visibility</p>
        <p class="mt-2 font-medium text-gray-900"><%= @current_request.visibility_label %></p>
      </article>
    </section>

    <section class="mb-10">
      <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-gray-400">Description</h2>
      <% if @current_request.description.present? %>
        <div class="whitespace-pre-wrap rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm leading-6 text-gray-800"><%= @current_request.description %></div>
      <% else %>
        <p class="text-sm text-gray-400">내용 없음</p>
      <% end %>
    </section>

    <section class="mb-10">
      <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-gray-400">Job</h2>

      <% if @current_request.service_desk_jobs.any? %>
        <ul class="space-y-4">
          <% @current_request.service_desk_jobs.each do |job| %>
            <li class="rounded-lg border border-gray-200 bg-gray-50 p-4">
              <div class="flex items-start justify-between gap-4">
                <p class="text-xs font-semibold text-gray-500"><%= job.job_number.to_s.rjust(4, "0") %> <%= job.author %> · <%= l(job.performed_at, format: :service_desk) %></p>
                <%= link_to "수정", edit_service_desk_request_job_path(@current_request, job.job_number), class: "shrink-0 text-xs text-gray-500 hover:text-blue-600" %>
              </div>
              <div class="mt-2 whitespace-pre-wrap text-sm leading-6 text-gray-800"><%= job.content %></div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-sm text-gray-400">아직 기록된 작업이 없습니다.</p>
      <% end %>

      <%= form_with model: @new_job, url: service_desk_request_jobs_path(@current_request), class: "mt-6 space-y-3 rounded-lg border border-gray-200 bg-white p-4" do |form| %>
        <h3 class="text-sm font-semibold text-gray-700">작업 내용 추가</h3>

        <% if @new_job.errors.any? %>
          <p class="text-sm text-red-600"><%= @new_job.errors.full_messages.to_sentence %></p>
        <% end %>

        <div>
          <%= form.label :content, "내용", class: "mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-400" %>
          <%= form.text_area :content, rows: 4, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
        </div>

        <%= form.submit "추가", class: "inline-flex items-center justify-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-blue-700" %>
      <% end %>
    </section>

    <div class="flex justify-between border-t border-gray-100 pt-8">
      <% if @prev_request %>
        <%= link_to service_desk_request_path(@prev_request), class: "flex items-center gap-2 text-sm text-gray-500 hover:text-blue-600" do %>
          <span>←</span>
          <span><%= @prev_request.subject %></span>
        <% end %>
      <% else %>
        <div></div>
      <% end %>

      <% if @next_request %>
        <%= link_to service_desk_request_path(@next_request), class: "flex items-center gap-2 text-sm text-gray-500 hover:text-blue-600" do %>
          <span><%= @next_request.subject %></span>
          <span>→</span>
        <% end %>
      <% end %>
    </div>
  </main>
</div>
