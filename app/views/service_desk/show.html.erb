<div class="min-h-screen bg-white">
  <%= render "shared/header" %>

  <div class="flex">
    <aside class="sticky top-14 hidden h-[calc(100vh-56px)] w-72 flex-shrink-0 overflow-y-auto border-r border-gray-200 bg-gray-50 lg:block">
      <div class="p-6">
        <div class="mb-6">
          <%= link_to "← 서비스데스크", service_desk_path, class: "mb-3 block text-sm text-gray-500 hover:text-blue-600" %>
          <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-400">서비스데스크 요청</h2>
        </div>

        <nav class="space-y-2">
          <% @requests.each do |request| %>
            <% current = request[:id] == @current_request[:id] %>

            <%= link_to service_desk_request_path(request[:id]),
                  class: "block rounded-lg border px-3 py-2 text-sm transition-colors #{current ? 'border-blue-200 bg-blue-50 text-blue-700' : 'border-gray-200 bg-white text-gray-700 hover:border-gray-300 hover:bg-gray-100'}" do %>
              <div class="flex items-start gap-3">
                <span class="mt-0.5 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-md text-xs font-semibold <%= current ? 'bg-blue-600 text-white' : 'bg-gray-200 text-gray-500' %>">
                  <%= request[:id] %>
                </span>
                <div class="min-w-0 flex-1">
                  <p class="truncate font-medium"><%= request[:subject] %></p>
                  <p class="mt-0.5 text-xs text-gray-400"><%= request[:status] %> · <%= request[:visibility] %></p>
                </div>
              </div>
            <% end %>
          <% end %>
        </nav>
      </div>
    </aside>

    <main class="min-w-0 flex-1 overflow-y-auto">
      <div class="max-w-4xl px-5 py-10 sm:px-7 sm:py-12">
        <div class="mb-8 border-b border-gray-100 pb-6">
          <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-blue-600">Request <%= @current_request[:id] %></p>
          <h1 class="text-3xl font-bold text-gray-900"><%= @current_request[:subject] %></h1>
          <p class="mt-3 text-sm text-gray-500">최종 업데이트: <%= l(@last_updated_at, format: :long) %></p>
        </div>

        <section class="mb-8 grid gap-4 sm:grid-cols-3">
          <article class="rounded-lg border border-gray-200 bg-gray-50 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-gray-400">Requester</p>
            <p class="mt-2 font-medium text-gray-900"><%= @current_request[:requester] %></p>
          </article>

          <article class="rounded-lg border border-gray-200 bg-gray-50 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-gray-400">Status</p>
            <p class="mt-2 font-medium text-gray-900"><%= @current_request[:status] %></p>
          </article>

          <article class="rounded-lg border border-gray-200 bg-gray-50 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-gray-400">Visibility</p>
            <p class="mt-2 font-medium text-gray-900"><%= @current_request[:visibility] %></p>
          </article>
        </section>

        <div class="doc-content max-w-none">
          <%= @content_html %>
        </div>
      </div>
    </main>
  </div>
</div>