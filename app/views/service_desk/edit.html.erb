<div class="min-h-screen bg-white">
  <%= render "shared/header" %>

  <main class="mx-auto w-full max-w-2xl px-5 py-10 sm:px-7 sm:py-12">
    <%= link_to "← #{@service_desk_request.to_param}로 돌아가기", service_desk_request_path(@service_desk_request), class: "mb-6 inline-block text-sm text-gray-500 hover:text-blue-600" %>

    <h1 class="mb-8 text-3xl font-bold text-gray-900">티켓 수정 — <%= @service_desk_request.to_param %></h1>

    <%= form_with model: @service_desk_request, url: service_desk_request_path(@service_desk_request), method: :patch, class: "space-y-5" do |form| %>
      <% if @service_desk_request.errors.any? %>
        <div class="rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-700">
          <%= @service_desk_request.errors.full_messages.to_sentence %>
        </div>
      <% end %>

      <div>
        <%= form.label :subject, "제목", class: "mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-400" %>
        <%= form.text_field :subject, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
      </div>

      <div>
        <%= form.label :status, "상태", class: "mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-400" %>
        <%= form.select :status,
              [ [ "New", "pending" ], [ "In Progress", "in_progress" ], [ "Completed", "completed" ], [ "Confirmed", "confirmed" ] ],
              {},
              class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
      </div>

      <div>
        <%= form.label :visibility, "공개 범위", class: "mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-400" %>
        <%= form.select :visibility,
              [ [ "Public", "visible" ], [ "Private", "restricted" ] ],
              {},
              class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
      </div>

      <div>
        <%= form.label :description, "내용", class: "mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-400" %>
        <%= form.text_area :description, rows: 6, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
      </div>

      <%= form.submit "저장", class: "inline-flex items-center justify-center rounded-lg bg-blue-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-blue-700" %>
    <% end %>
  </main>
</div>
