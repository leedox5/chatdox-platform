<div class="min-h-screen bg-gray-50">
  <%= render "shared/header" %>

  <main class="mx-auto w-full max-w-5xl px-5 py-10 sm:px-7 sm:py-12">
    <div class="mb-8 flex flex-wrap items-end justify-between gap-4 border-b border-gray-100 pb-6">
      <div>
        <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-blue-600">Web Service Desk</p>
        <h1 class="text-3xl font-bold text-gray-900">서비스데스크</h1>
        <p class="mt-3 text-sm text-gray-500">팀과 AI 에이전트가 웹에서 직접 발행/기록하는 운영 티켓입니다. 정책 결정은 git 쪽 서비스데스크에 남습니다.</p>
      </div>

      <div class="flex flex-wrap gap-2">
        <%= link_to "새 티켓 발행", new_service_desk_request_path, class: "inline-flex items-center justify-center rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-blue-700" %>
        <%= button_to "전체 export", service_desk_export_path,
              form: { data: { turbo: false } },
              class: "inline-flex items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-700 transition hover:border-gray-400 hover:bg-gray-50" %>
      </div>
    </div>

    <section class="mb-8 grid gap-4 sm:grid-cols-2">
      <article class="rounded-lg border border-gray-200 bg-white p-5">
        <div class="mb-3 flex items-center justify-between">
          <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-400">내 관련</h2>
          <span class="rounded-full bg-blue-50 px-2.5 py-0.5 text-xs font-semibold text-blue-600"><%= @my_related_requests.size %>건</span>
        </div>
        <% if @my_related_requests.any? %>
          <ul class="space-y-2">
            <% @my_related_requests.first(3).each do |request| %>
              <li><%= render "request_summary", service_desk_request: request %></li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-sm text-gray-400">관련된 티켓이 없습니다.</p>
        <% end %>
      </article>

      <article class="rounded-lg border border-gray-200 bg-white p-5">
        <div class="mb-3 flex items-center justify-between">
          <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-400">신규</h2>
          <span class="rounded-full bg-green-50 px-2.5 py-0.5 text-xs font-semibold text-green-600"><%= @new_requests.size %>건</span>
        </div>
        <% if @new_requests.any? %>
          <ul class="space-y-2">
            <% @new_requests.first(3).each do |request| %>
              <li><%= render "request_summary", service_desk_request: request %></li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-sm text-gray-400">New 상태 티켓이 없습니다.</p>
        <% end %>
      </article>
    </section>

    <% if @requests.empty? %>
      <p class="rounded-lg border border-gray-200 bg-white p-6 text-sm text-gray-500">아직 발행된 티켓이 없습니다.</p>
    <% else %>
      <ul class="space-y-3">
        <% @requests.each do |request| %>
          <li><%= render "request_summary", service_desk_request: request %></li>
        <% end %>
      </ul>
    <% end %>
  </main>
</div>
