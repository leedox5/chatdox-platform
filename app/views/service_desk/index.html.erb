<div class="min-h-screen bg-gray-50">
  <%= render "shared/header" %>

  <main class="mx-auto w-full max-w-5xl px-5 py-10 sm:px-7 sm:py-12">
    <div class="mb-8 flex flex-wrap items-end justify-between gap-4 border-b border-gray-100 pb-6">
      <div>
        <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-blue-600">Web Service Desk</p>
        <h1 class="text-3xl font-bold text-gray-900">서비스데스크</h1>
        <p class="mt-3 text-sm text-gray-500">팀과 AI 에이전트가 웹에서 직접 발행/기록하는 운영 티켓입니다. 정책 결정은 git 쪽 서비스데스크에 남습니다.</p>
      </div>

      <div class="flex flex-wrap gap-2">
        <%= link_to "새 티켓 발행", new_service_desk_request_path, class: "inline-flex items-center justify-center rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-blue-700" %>
        <%= button_to "전체 export", service_desk_export_path, class: "inline-flex items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-700 transition hover:border-gray-400 hover:bg-gray-50" %>
      </div>
    </div>

    <% if @requests.empty? %>
      <p class="rounded-lg border border-gray-200 bg-white p-6 text-sm text-gray-500">아직 발행된 티켓이 없습니다.</p>
    <% else %>
      <ul class="space-y-3">
        <% @requests.each do |request| %>
          <li>
            <%= link_to service_desk_request_path(request), class: "block rounded-lg border border-gray-200 bg-white p-4 transition hover:border-blue-300 hover:bg-blue-50" do %>
              <div class="flex items-start gap-3">
                <span class="mt-0.5 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-md bg-gray-100 text-xs font-semibold text-gray-500">
                  <%= request.to_param %>
                </span>
                <div class="min-w-0 flex-1">
                  <p class="font-medium text-gray-900"><%= request.subject %></p>
                  <p class="mt-1 text-xs text-gray-400"><%= request.requester %> · <%= request.status_label %> · <%= request.visibility_label %> · <%= l(request.date, format: :long) %></p>
                </div>
              </div>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% end %>
  </main>
</div>
