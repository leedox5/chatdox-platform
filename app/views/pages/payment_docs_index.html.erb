<% content_for :title, "결제 시스템 문서" %>

<%= render "shared/header" %>

<div class="mx-auto max-w-6xl px-4 py-8">
  <div class="mb-12">
    <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-blue-600">Admin Docs</p>
    <h1 class="text-4xl font-bold text-gray-900">결제 시스템 문서</h1>
    <p class="mt-3 text-lg text-gray-600">토스페이먼츠 / 포트원 연동 상태 및 기술 문서</p>
  </div>

  <div class="grid gap-6 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
    <% @payment_sections.each do |section| %>
      <%= link_to admin_payment_docs_section_path(section[:slug]), class: "block p-6 bg-white rounded-lg shadow hover:shadow-lg transition border border-gray-100 hover:border-blue-300" do %>
        <div class="flex items-start justify-between">
          <div>
            <p class="text-sm font-semibold text-blue-600 uppercase tracking-wide">Section <%= section[:id] %></p>
            <h3 class="mt-2 text-xl font-bold text-gray-900"><%= section[:title] %></h3>
          </div>
          <span class="text-2xl text-gray-300">→</span>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
