<% content_for :title, @current_section[:title] %>

<%= render "shared/header" %>

<div class="flex h-[calc(100vh-57px)] bg-gray-50">
  <!-- 사이드바 -->
  <aside class="w-64 border-r border-gray-200 bg-white overflow-y-auto">
    <div class="sticky top-0 bg-white px-5 py-6 border-b border-gray-100">
      <%= link_to "← 돌아가기", admin_payment_docs_path, class: "text-sm text-gray-600 hover:text-gray-900 font-medium" %>
    </div>

    <nav class="flex-1 px-5 py-6">
      <div class="space-y-1">
        <% @all_sections.each do |section| %>
          <% is_current = section[:slug] == @current_section[:slug] %>
          <%= link_to admin_payment_docs_section_path(section[:slug]), 
              class: "block px-4 py-3 rounded-lg text-sm font-medium transition #{is_current ? 'bg-blue-50 text-blue-600 border border-blue-200' : 'text-gray-700 hover:bg-gray-50'}" do %>
            <span class="text-xs text-gray-500 font-semibold uppercase tracking-wide"><%= section[:id] %></span>
            <p class="mt-1"><%= section[:title] %></p>
          <% end %>
        <% end %>
      </div>
    </nav>
  </aside>

  <!-- 메인 콘텐츠 -->
  <div class="flex-1 flex flex-col overflow-hidden">
    <main class="min-w-0 flex-1 overflow-y-auto">
      <div class="max-w-3xl px-5 py-10 sm:px-7 sm:py-12">
        <!-- 헤더 -->
        <div class="mb-8 border-b border-gray-100 pb-6">
          <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-blue-600">Section <%= @current_section[:id] %></p>
          <h1 class="text-3xl font-bold text-gray-900"><%= @current_section[:title] %></h1>
        </div>

        <!-- 콘텐츠 -->
        <div class="doc-content max-w-none">
          <%= @content_html %>
        </div>

        <!-- 네비게이션 -->
        <div class="mt-16 border-t border-gray-100 pt-8">
          <div class="flex items-center justify-between">
            <% if @prev_section %>
              <%= link_to admin_payment_docs_section_path(@prev_section[:slug]), class: "flex items-center gap-2 text-sm text-gray-500 hover:text-blue-600" do %>
                <span>←</span>
                <span><%= @prev_section[:title] %></span>
              <% end %>
            <% else %>
              <div></div>
            <% end %>

            <% if @next_section %>
              <%= link_to admin_payment_docs_section_path(@next_section[:slug]), class: "flex items-center gap-2 text-sm text-gray-500 hover:text-blue-600" do %>
                <span><%= @next_section[:title] %></span>
                <span>→</span>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>
