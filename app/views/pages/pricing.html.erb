<% content_for :title, "가격 | LEEDOX" %>

<div class="min-h-screen bg-slate-50">
  <%= render "shared/header" %>

  <main class="mx-auto w-full max-w-6xl px-4 py-16 sm:px-6">
    <div class="mb-10">
      <p class="text-sm font-black uppercase tracking-[0.18em] text-indigo-700">Pricing</p>
      <h1 class="mt-2 break-keep text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">상품별 가격</h1>
      <p class="mt-3 max-w-2xl break-keep text-slate-600">LEEDOX가 제공하는 상품들을 한눈에 확인하세요. 자세한 구성과 전체 가격표는 각 상품 페이지에서 볼 수 있습니다.</p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <% @products.each do |product| %>
        <% sales_enabled = Commerce::Sales.enabled_for?(product) %>
        <% cheapest_offer = product.product_offers.active.ordered.first %>
        <article class="flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <div class="flex items-center justify-between gap-3">
            <h2 class="text-xl font-black tracking-tight text-slate-950"><%= product.name %></h2>
            <% if sales_enabled %>
              <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-bold text-emerald-700">판매 중</span>
            <% else %>
              <span class="rounded-full bg-amber-50 px-3 py-1 text-xs font-bold text-amber-700">준비 중</span>
            <% end %>
          </div>

          <p class="mt-3 flex-1 break-keep text-sm leading-6 text-slate-600"><%= PagesController::PRODUCT_TAGLINES[product.code] %></p>

          <p class="mt-5 text-2xl font-black text-slate-950">
            <% if cheapest_offer %>
              최저 <%= number_with_delimiter(cheapest_offer.total_amount) %>원부터
            <% else %>
              가격 준비 중
            <% end %>
          </p>

          <% detail_path_helper = PagesController::PRODUCT_DETAIL_PATH_HELPERS[product.code] %>
          <% if detail_path_helper %>
            <%= link_to "자세히 보기", public_send(detail_path_helper),
              class: "mt-6 inline-flex items-center justify-center rounded-xl bg-slate-950 px-5 py-3 text-sm font-bold text-white transition hover:bg-indigo-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2" %>
          <% end %>
        </article>
      <% end %>
    </div>
  </main>

  <%= render "shared/footer" %>
</div>
