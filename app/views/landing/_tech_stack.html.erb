<section class="py-16">
  <div class="mx-auto w-full max-w-6xl px-4 sm:px-6">
    <div class="mb-10">
      <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">기술 스택</h2>
      <p class="mt-3 text-slate-600">초기 비용 부담을 낮추고 빠르게 운영 가능한 조합으로 구성했습니다.</p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <% [
        ["Ruby on Rails 8.1", "웹 프레임워크"],
        ["Ruby 3.3", "프로그래밍 언어"],
        ["SQLite3 / PostgreSQL", "데이터베이스"],
        ["Devise", "사용자 인증"],
        ["Tailwind CSS", "스타일링 & UI"],
        ["토스페이먼츠", "결제 처리"],
        ["ActiveStorage", "파일 관리"]
      ].each do |name, desc| %>
        <article class="rounded-xl border border-slate-200 bg-white p-5 hover:shadow-lg">
          <h3 class="font-semibold text-slate-900"><%= name %></h3>
          <p class="mt-1 text-sm text-slate-600"><%= desc %></p>
        </article>
      <% end %>
    </div>
  </div>
</section>
