<section id="docs" class="py-16">
  <% chapters = DocsController::CHAPTERS %>
  <% phases = DocsController::PHASES %>

  <div class="mx-auto w-full max-w-6xl px-4 sm:px-6">
    <div class="mb-10">
      <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">완전한 커리큘럼 (20개 챕터)</h2>
      <p class="mt-3 text-slate-600">기초부터 배포와 운영까지, 실제 서비스 구축 순서대로 구성되어 있습니다.</p>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
      <% phases.each do |phase| %>
        <% phase_chapters = chapters.select { |chapter| phase[:range].cover?(chapter[:id].to_i) } %>

        <article class="rounded-xl border border-slate-200 bg-white p-6 hover:shadow-lg">
          <h3 class="text-lg font-bold text-slate-900"><%= phase[:title] %> (<%= phase_chapters.size %>개)</h3>
          <ol class="mt-4 space-y-3 text-sm text-slate-600">
            <% phase_chapters.each do |chapter| %>
              <li>
                <%= link_to doc_path(chapter[:id]), class: "transition-colors hover:text-blue-600" do %>
                  <%= chapter[:id].to_i %>. <%= chapter[:title] %>
                <% end %>
              </li>
            <% end %>
          </ol>
        </article>
      <% end %>
    </div>
  </div>
</section>
