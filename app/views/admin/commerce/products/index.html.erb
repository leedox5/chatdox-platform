<% content_for :title, "상품 판매여부 관리" %>

<div class="min-h-screen bg-slate-50">
  <%= render "shared/header" %>
  <main class="mx-auto max-w-5xl px-4 py-10 sm:px-6 lg:px-8">
    <header class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-blue-700">Admin Commerce</p>
        <h1 class="mt-2 text-3xl font-black text-slate-950">상품 판매여부 관리</h1>
        <p class="mt-2 text-slate-600">판매 on/off만 여기서 바꿉니다. 가격·기간(ProductOffer)은 시딩으로만 관리됩니다.</p>
      </div>
      <%= link_to "관리자 대시보드", admin_dashboard_path, class: "text-sm font-bold text-blue-700 hover:underline" %>
    </header>

    <section class="mt-8 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-bold uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-4 py-3">코드</th>
            <th class="px-4 py-3">활성</th>
            <th class="px-4 py-3">판매 상태</th>
            <th class="px-4 py-3">이용권(ProductOffer)</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @products.each do |product| %>
            <tr class="align-top">
              <td class="px-4 py-4"><strong><%= product.name %></strong><p class="text-xs text-slate-500"><%= product.code %></p></td>
              <td class="px-4 py-4"><%= product.active? ? "활성" : "비활성" %></td>
              <td class="px-4 py-4">
                <span class="rounded-full px-3 py-1 text-xs font-bold <%= product.sale_enabled? ? "bg-emerald-100 text-emerald-700" : "bg-slate-200 text-slate-600" %>">
                  <%= product.sale_enabled? ? "판매 중" : "판매 중지" %>
                </span>
              </td>
              <td class="px-4 py-4">
                <% if product.product_offers.any? %>
                  <ul class="space-y-1 text-xs text-slate-600">
                    <% product.product_offers.ordered.each do |offer| %>
                      <li><%= offer.duration_months %>개월 · <%= number_with_delimiter(offer.total_amount) %><%= offer.currency %><%= " (비활성)" unless offer.active? %></li>
                    <% end %>
                  </ul>
                <% else %>
                  <span class="text-slate-400">없음</span>
                <% end %>
              </td>
              <td class="px-4 py-4 text-right">
                <%= button_to product.sale_enabled? ? "판매 중지" : "판매 시작",
                  admin_commerce_product_path(product),
                  method: :patch,
                  class: "rounded-lg border border-blue-200 bg-white px-3 py-1.5 font-semibold text-blue-700 transition hover:bg-blue-50" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <% if @products.empty? %><p class="p-8 text-center text-slate-500">등록된 상품이 없습니다.</p><% end %>
    </section>
  </main>
</div>
