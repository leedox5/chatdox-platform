<% content_for :title, "GitHub 계정 연결 운영" %>
<div class="min-h-screen bg-slate-50">
  <%= render "shared/header" %>
  <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div><p class="text-sm font-bold uppercase tracking-[0.2em] text-indigo-700">External Accounts</p><h1 class="mt-2 text-3xl font-black">GitHub 계정 연결</h1></div>
      <%= link_to "수동 작업 대기열", admin_commerce_external_access_tasks_path, class: "font-semibold text-indigo-700 hover:underline" %>
    </div>
    <%= form_with url: admin_commerce_external_account_links_path, method: :get, class: "mt-6 flex flex-wrap gap-3 rounded-2xl border bg-white p-4" do |form| %>
      <%= form.select :status, options_for_select([["전체 상태", ""]] + ExternalAccountLink::STATUSES.map { |value| [external_link_status_label(value), value] }, params[:status]), {}, class: "rounded-lg border px-3 py-2" %>
      <%= form.submit "조회", class: "rounded-lg bg-slate-900 px-4 py-2 font-semibold text-white" %>
    <% end %>
    <div class="mt-6 overflow-x-auto rounded-2xl border bg-white shadow-sm">
      <table class="min-w-full text-left text-sm"><thead class="bg-slate-50 text-slate-600"><tr><th class="p-4">사용자</th><th class="p-4">GitHub</th><th class="p-4">Link</th><th class="p-4">Grant</th><th class="p-4">Task</th></tr></thead>
        <tbody class="divide-y"><% @links.each do |link| %><tr><td class="p-4"><%= masked_external_access_user(link.user) %></td><td class="p-4"><%= link_to "@#{link.username}", admin_commerce_external_account_link_path(link.public_id), class: "font-semibold text-indigo-700" %></td><td class="p-4"><%= link.status %></td><td class="p-4"><%= link.external_access_grants.map(&:status).join(", ").presence || "없음" %></td><td class="p-4"><%= link.external_access_tasks.count { |task| ExternalAccessTask::OPEN_STATUSES.include?(task.status) } %> open</td></tr><% end %></tbody>
      </table>
    </div>
  </main>
</div>
