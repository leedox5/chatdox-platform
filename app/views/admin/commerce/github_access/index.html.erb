<% content_for :title, "GitHub Lab 운영" %>

<div class="min-h-screen bg-slate-50">
  <%= render "shared/header" %>
  <main class="mx-auto max-w-5xl px-4 py-10 sm:px-6 lg:px-8">
    <header>
      <p class="text-sm font-bold uppercase tracking-[0.2em] text-indigo-700">GitHub Lab Operations</p>
      <h1 class="mt-2 text-3xl font-black text-slate-950">GitHub Lab 접근 운영</h1>
      <p class="mt-2 text-slate-600">실제 초대·제거는 관리자가 GitHub에서 직접 처리합니다. 이 화면은 처리 여부만 기록합니다.</p>
    </header>

    <section class="mt-8">
      <h2 class="text-lg font-bold text-slate-900">초대 필요 (<%= @needs_invite.size %>)</h2>
      <div class="mt-3 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
          <thead class="bg-slate-50 text-left text-xs font-bold uppercase tracking-wide text-slate-500">
            <tr><th class="px-4 py-3">사용자</th><th class="px-4 py-3">GitHub</th><th class="px-4 py-3"></th></tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @needs_invite.each do |link| %>
              <tr>
                <td class="px-4 py-3"><%= masked_email(link.user) %></td>
                <td class="px-4 py-3">@<%= link.username %></td>
                <td class="px-4 py-3 text-right">
                  <%= button_to "초대 완료", admin_commerce_invite_github_access_path(link.public_id), method: :patch,
                    class: "rounded-lg bg-indigo-700 px-3 py-1.5 font-semibold text-white hover:bg-indigo-800" %>
                </td>
              </tr>
            <% end %>
            <% if @needs_invite.empty? %>
              <tr><td colspan="3" class="px-4 py-6 text-center text-slate-500">초대가 필요한 계정이 없습니다.</td></tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-8">
      <h2 class="text-lg font-bold text-slate-900">회수 필요 (<%= @needs_revoke.size %>)</h2>
      <div class="mt-3 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
          <thead class="bg-slate-50 text-left text-xs font-bold uppercase tracking-wide text-slate-500">
            <tr><th class="px-4 py-3">사용자</th><th class="px-4 py-3">GitHub</th><th class="px-4 py-3">초대일</th><th class="px-4 py-3"></th></tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @needs_revoke.each do |link| %>
              <tr>
                <td class="px-4 py-3"><%= masked_email(link.user) %></td>
                <td class="px-4 py-3">@<%= link.username %></td>
                <td class="px-4 py-3"><%= I18n.l(link.invited_at.to_date, format: :long, locale: :ko) %></td>
                <td class="px-4 py-3 text-right">
                  <%= button_to "회수 완료", admin_commerce_revoke_github_access_path(link.public_id), method: :patch,
                    class: "rounded-lg bg-amber-700 px-3 py-1.5 font-semibold text-white hover:bg-amber-800" %>
                </td>
              </tr>
            <% end %>
            <% if @needs_revoke.empty? %>
              <tr><td colspan="4" class="px-4 py-6 text-center text-slate-500">회수가 필요한 계정이 없습니다.</td></tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</div>
