<% content_for :title, "환불 요청 심사" %>

<div class="min-h-screen bg-slate-50">
  <%= render "shared/header" %>
  <main class="mx-auto w-full max-w-5xl px-4 py-10 sm:px-6">
    <%= link_to "← 주문 상세", admin_commerce_order_path(@order.public_id), class: "text-sm font-bold text-blue-700 hover:underline" %>
    <header class="mt-5"><p class="text-sm font-black uppercase tracking-[0.18em] text-indigo-700">Refund review</p><h1 class="mt-2 break-keep text-3xl font-black text-slate-950">환불 요청 심사</h1></header>

    <div class="mt-7 grid gap-5 lg:grid-cols-2">
      <section class="rounded-2xl border border-slate-200 bg-white p-6">
        <h2 class="font-bold">주문·이용 요약</h2>
        <dl class="mt-4 space-y-3 text-sm">
          <div class="flex justify-between gap-4"><dt>고객</dt><dd><%= masked_email(@refund_request.user) %></dd></div>
          <div class="flex justify-between gap-4"><dt>상품·결제액</dt><dd><%= @order.order_items.first.product_name %> · <%= number_with_delimiter(@order.total_amount) %>원</dd></div>
          <div class="flex justify-between gap-4"><dt>PG·Transaction</dt><dd><%= @order.provider %> · <%= @order.payment_transaction&.status %></dd></div>
          <div class="flex justify-between gap-4"><dt>License</dt><dd><%= @order.licenses.map { |license| "#{license.effective_status} #{license.starts_on}~#{license.last_usable_on}" }.join(", ") %></dd></div>
          <div class="flex justify-between gap-4"><dt>요청 상태</dt><dd class="font-bold"><%= refund_status_label(@refund_request.status) %></dd></div>
          <div class="flex justify-between gap-4"><dt>외부 환불</dt><dd><%= @refund_request.provider_refund_status %> / 확인 <%= @refund_request.external_refund_confirmed? ? "예" : "아니오" %></dd></div>
        </dl>
      </section>
      <section class="rounded-2xl border border-slate-200 bg-white p-6">
        <h2 class="font-bold">고객 요청</h2><p class="mt-3 text-sm"><strong><%= @refund_request.reason_code %></strong></p><p class="mt-3 whitespace-pre-wrap break-words text-sm text-slate-600"><%= @refund_request.customer_note.presence || "설명 없음" %></p>
      </section>
    </div>

    <%= form_with model: @refund_request, url: admin_commerce_refund_request_path(@refund_request.public_id), method: :patch, class: "mt-5 space-y-5 rounded-2xl border border-slate-200 bg-white p-6" do |form| %>
      <h2 class="font-bold">심사 기록</h2>
      <div><%= form.label :public_response, "고객 공개 안내", class: "block text-sm font-bold" %><%= form.text_area :public_response, maxlength: 2_000, rows: 4, class: "mt-2 w-full rounded-lg border border-slate-300 p-3" %></div>
      <div><%= form.label :internal_note, "내부 판단 근거 (고객 비공개)", class: "block text-sm font-bold" %><%= form.text_area :internal_note, maxlength: 2_000, rows: 4, class: "mt-2 w-full rounded-lg border border-slate-300 p-3" %></div>
      <div class="flex flex-wrap gap-3">
        <% actions = case @refund_request.status; when "requested" then [["검토 시작", "start_review"]]; when "reviewing" then [["승인", "approve"], ["거절", "reject"], ["메모 저장", "update_notes"]]; when "approved" then [["외부 처리 대기", "mark_processing"], ["메모 저장", "update_notes"]]; else [["메모 저장", "update_notes"]]; end %>
        <% actions.each do |label, action_name| %><button type="submit" name="refund_request[action_name]" value="<%= action_name %>" class="rounded-lg bg-slate-900 px-4 py-2 font-bold text-white"><%= label %></button><% end %>
      </div>
      <p class="text-xs text-slate-500">승인과 외부 처리 대기는 실제 PG 환불 완료가 아닙니다. 이 화면에서는 refunded 확정, Order 상태 변경과 License 변경을 수행하지 않습니다.</p>
    <% end %>

    <section class="mt-5 rounded-2xl border border-slate-200 bg-white p-6"><h2 class="font-bold">감사 이력</h2><ul class="mt-3 divide-y divide-slate-100 text-sm"><% @audits.each do |audit| %><li class="py-3"><strong><%= audit.action %></strong> · <%= audit.from_state || "-" %> → <%= audit.to_state || "-" %> · actor <%= audit.actor ? masked_email(audit.actor) : "system" %> · <%= audit.occurred_at %></li><% end %></ul></section>
  </main>
</div>
