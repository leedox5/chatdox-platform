<% content_for :title, "Commerce 주문 상세" %>

<div class="min-h-screen bg-slate-50">
  <%= render "shared/header" %>
  <main class="mx-auto w-full max-w-5xl px-4 py-10 sm:px-6">
    <%= link_to "← 주문 목록", admin_commerce_orders_path, class: "text-sm font-bold text-blue-700 hover:underline" %>
    <header class="mt-5">
      <p class="text-sm font-black uppercase tracking-[0.18em] text-blue-700">Order <%= @order.public_id.first(8) %></p>
      <h1 class="mt-2 break-keep text-3xl font-black text-slate-950"><%= @order.order_items.first.product_name %> 주문 상세</h1>
    </header>

    <% if @issues.any? %><div class="mt-6 rounded-xl border border-red-200 bg-red-50 p-4 text-sm font-bold text-red-800">정합성 확인: <%= @issues.map(&:code).join(", ") %></div><% end %>

    <div class="mt-7 grid gap-5 lg:grid-cols-2">
      <section class="rounded-2xl border border-slate-200 bg-white p-6">
        <h2 class="font-bold text-slate-900">Order snapshot</h2>
        <dl class="mt-4 grid gap-3 text-sm sm:grid-cols-2">
          <div><dt class="text-slate-500">사용자</dt><dd><%= masked_email(@order.user) %></dd></div>
          <div><dt class="text-slate-500">상태</dt><dd><%= order_status_label(@order.status) %></dd></div>
          <div><dt class="text-slate-500">Provider</dt><dd><%= @order.provider %></dd></div>
          <div><dt class="text-slate-500">금액</dt><dd><%= number_with_delimiter(@order.supply_amount) %> + VAT <%= number_with_delimiter(@order.vat_amount) %> = <%= number_with_delimiter(@order.total_amount) %>원</dd></div>
          <div><dt class="text-slate-500">요청 시작일</dt><dd><%= @order.requested_start_on %></dd></div>
          <div><dt class="text-slate-500">생성/결제/확정</dt><dd><%= @order.created_at %><br><%= @order.paid_at || "-" %><br><%= @order.finalized_at || "-" %></dd></div>
        </dl>
      </section>
      <section class="rounded-2xl border border-slate-200 bg-white p-6">
        <h2 class="font-bold text-slate-900">Pending 안전 판정</h2>
        <dl class="mt-4 grid gap-3 text-sm sm:grid-cols-2">
          <div><dt class="text-slate-500">분류</dt><dd class="font-bold"><%= @assessment.classification %></dd></div>
          <div><dt class="text-slate-500">판정 code</dt><dd><%= @assessment.reason_code %></dd></div>
          <div><dt class="text-slate-500">Provider ID</dt><dd><%= @assessment.provider_payment_id_present ? "존재" : "없음" %></dd></div>
          <div><dt class="text-slate-500">성공 흔적</dt><dd><%= @assessment.success_evidence ? "존재" : "없음" %></dd></div>
          <div><dt class="text-slate-500">마지막 provider 사건</dt><dd><%= @assessment.last_event_at || "없음" %></dd></div>
          <div><dt class="text-slate-500">정리 가능</dt><dd><%= @assessment.safe_to_abandon ? "가능" : "불가/확인 필요" %></dd></div>
        </dl>
        <% if @assessment.safe_to_abandon %><%= button_to "결제 이탈로 정리", abandon_admin_commerce_order_path(@order.public_id), data: { turbo_confirm: "PG 성공 흔적이 없음을 확인했습니까?" }, class: "mt-5 rounded-lg bg-amber-600 px-4 py-2 font-bold text-white" %><% end %>
      </section>
    </div>

    <section class="mt-5 rounded-2xl border border-slate-200 bg-white p-6">
      <h2 class="font-bold text-slate-900">Transaction · License · Refund</h2>
      <% transaction = @order.payment_transaction %>
      <div class="mt-4 grid gap-5 text-sm md:grid-cols-3">
        <div><h3 class="font-bold">Transaction</h3><p class="mt-2">상태 <%= transaction&.status || "없음" %></p><p>Provider 상태 <%= transaction&.provider_status.presence || "미확인" %></p></div>
        <div><h3 class="font-bold">License</h3><% @order.licenses.each do |license| %><p class="mt-2"><%= license.effective_status %> · <%= license.starts_on %> ~ <%= license.last_usable_on %></p><% end %><%= "없음" if @order.licenses.empty? %></div>
        <div><h3 class="font-bold">환불 요청</h3><% @order.refund_requests.each do |request| %><p class="mt-2"><%= link_to refund_status_label(request.status), admin_commerce_refund_request_path(request.public_id), class: "font-bold text-indigo-700 hover:underline" %></p><% end %><%= "없음" if @order.refund_requests.empty? %></div>
      </div>
      <p class="mt-5 rounded-lg bg-slate-50 p-3 text-xs text-slate-500">전체 provider payload, secret, 결제수단 상세는 표시하지 않습니다.</p>
    </section>

    <section class="mt-5 rounded-2xl border border-slate-200 bg-white p-6">
      <h2 class="font-bold text-slate-900">Order 감사 이력</h2>
      <ul class="mt-3 divide-y divide-slate-100 text-sm"><% @audits.each do |audit| %><li class="py-3"><strong><%= audit.action %></strong> · <%= audit.from_state || "-" %> → <%= audit.to_state || "-" %> · actor <%= audit.actor ? masked_email(audit.actor) : "system" %> · <%= audit.occurred_at %></li><% end %></ul>
    </section>
  </main>
</div>
