<% content_for :title, "GitHub Lab 수동 작업 상세" %>
<div class="min-h-screen bg-slate-50"><%= render "shared/header" %><main class="mx-auto max-w-5xl px-4 py-10 sm:px-6 lg:px-8">
  <%= link_to "← 작업 대기열", admin_commerce_external_access_tasks_path, class: "font-semibold text-indigo-700" %>
  <p class="mt-6 text-sm font-bold uppercase tracking-[0.2em] text-indigo-700">Manual Operation</p><h1 class="mt-2 break-keep text-3xl font-black"><%= external_task_label(@task.task_type) %></h1>
  <div class="mt-6 rounded-2xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">실제 GitHub 화면에서 작업을 완료하거나 확인하기 전에는 완료로 기록하지 마세요. 이 서비스는 GitHub API를 호출하지 않습니다.</div>
  <div class="mt-6 grid gap-5 md:grid-cols-2"><section class="rounded-2xl border bg-white p-5"><h2 class="font-bold">대상</h2><dl class="mt-3 space-y-2 text-sm"><div><dt class="text-slate-500">사용자</dt><dd><%= masked_external_access_user(@link.user) %></dd></div><div><dt class="text-slate-500">GitHub</dt><dd class="break-all">@<%= @link.username %></dd></div><div><dt class="text-slate-500">Link</dt><dd><%= @link.status %></dd></div><div><dt class="text-slate-500">Grant</dt><dd><%= @grant&.status || "-" %></dd></div></dl></section><section class="rounded-2xl border bg-white p-5"><h2 class="font-bold">작업</h2><dl class="mt-3 space-y-2 text-sm"><div><dt class="text-slate-500">상태</dt><dd><%= @task.status %></dd></div><div><dt class="text-slate-500">기한</dt><dd><%= @task.due_at %></dd></div><div><dt class="text-slate-500">이전 실패</dt><dd><%= @task.reason_code || "없음" %></dd></div></dl></section></div>
  <section class="mt-6 rounded-2xl border bg-white p-5"><h2 class="font-bold">처리 기록</h2><%= form_with model: @task, url: admin_commerce_external_access_task_path(@task.public_id), method: :patch, class: "mt-4 space-y-4" do |form| %>
    <% if %w[verify_account process_account_change].include?(@task.task_type) %><div><%= form.label :external_uid, "확인한 GitHub numeric user ID (선택)", class: "block text-sm font-semibold" %><%= form.text_field :external_uid, inputmode: "numeric", autocomplete: "off", class: "mt-2 w-full rounded-lg border px-3 py-2" %></div><% end %>
    <div><%= form.label :evidence_note, "제한된 확인 근거", class: "block text-sm font-semibold" %><%= form.text_area :evidence_note, maxlength: 1000, rows: 3, class: "mt-2 w-full rounded-lg border px-3 py-2" %></div>
    <div><%= form.label :public_message, "고객 공개 안내", class: "block text-sm font-semibold" %><%= form.text_area :public_message, maxlength: 1000, rows: 3, class: "mt-2 w-full rounded-lg border px-3 py-2" %></div>
    <div><%= form.label :internal_note, "내부 메모 (고객 비공개)", class: "block text-sm font-semibold" %><%= form.text_area :internal_note, maxlength: 1000, rows: 3, class: "mt-2 w-full rounded-lg border px-3 py-2" %></div>
    <div class="flex flex-wrap gap-3"><% if @task.status == "pending" %><button name="external_access_task[action_name]" value="complete" class="rounded-lg bg-slate-900 px-4 py-2 font-semibold text-white">수동 작업 완료 기록</button><% end %><% if @task.status == "failed" && @task.retryable? %><button name="external_access_task[action_name]" value="retry" class="rounded-lg bg-indigo-700 px-4 py-2 font-semibold text-white">재시도 대기</button><% end %></div>
    <% if @task.status == "pending" %><div class="border-t pt-4"><%= form.select :reason_code, options_for_select([["실패 사유", ""]] + ExternalAccessTask::REASON_CODES.map { |value| [value, value] }), {}, class: "rounded-lg border px-3 py-2" %><%= form.hidden_field :retryable, value: true %><button name="external_access_task[action_name]" value="fail" class="ml-2 rounded-lg border border-red-200 px-4 py-2 font-semibold text-red-700">실패 기록</button></div><% end %>
  <% end %></section>
  <section class="mt-6 rounded-2xl border bg-white p-5"><h2 class="font-bold">감사 Event</h2><ul class="mt-3 divide-y text-sm"><% @events.each do |event| %><li class="py-3"><%= event.occurred_at %> · <%= event.action %> · <%= event.from_state %> → <%= event.to_state %> · <%= event.reason_code %></li><% end %></ul></section>
</main></div>
