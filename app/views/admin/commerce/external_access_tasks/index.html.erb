<% content_for :title, "GitHub Lab 수동 작업" %>
<div class="min-h-screen bg-slate-50"><%= render "shared/header" %><main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
  <div class="flex flex-wrap items-end justify-between gap-4"><div><p class="text-sm font-bold uppercase tracking-[0.2em] text-indigo-700">GitHub Lab Operations</p><h1 class="mt-2 text-3xl font-black">수동 작업 대기열</h1><p class="mt-2 text-slate-600">이 화면은 실제 GitHub 작업을 호출하지 않습니다. GitHub에서 수동 작업을 완료한 뒤 결과만 기록하세요.</p></div><%= link_to "계정 연결 목록", admin_commerce_external_account_links_path, class: "font-semibold text-indigo-700" %></div>
  <%= form_with url: admin_commerce_external_access_tasks_path, method: :get, class: "mt-6 grid gap-3 rounded-2xl border bg-white p-4 sm:grid-cols-2 lg:grid-cols-4" do |form| %>
    <%= form.select :task_type, options_for_select([["전체 작업", ""]] + ExternalAccessTask::TASK_TYPES.map { |value| [external_task_label(value), value] }, params[:task_type]), {}, class: "rounded-lg border px-3 py-2" %>
    <%= form.select :status, options_for_select([["전체 상태", ""]] + ExternalAccessTask::STATUSES.map { |value| [value, value] }, params[:status]), {}, class: "rounded-lg border px-3 py-2" %>
    <%= form.select :due, options_for_select([["전체 기한", ""], ["기한 초과", "overdue"], ["기한 내", "due"]], params[:due]), {}, class: "rounded-lg border px-3 py-2" %>
    <%= form.select :link_status, options_for_select([["전체 Link", ""]] + ExternalAccountLink::STATUSES.map { |value| [value, value] }, params[:link_status]), {}, class: "rounded-lg border px-3 py-2" %>
    <%= form.select :grant_status, options_for_select([["전체 Grant", ""]] + ExternalAccessGrant::STATUSES.map { |value| [value, value] }, params[:grant_status]), {}, class: "rounded-lg border px-3 py-2" %>
    <%= form.select :product, options_for_select([["전체 상품", ""], ["Chatdox", "chatdox"]], params[:product]), {}, class: "rounded-lg border px-3 py-2" %>
    <%= form.select :license_status, options_for_select([["전체 License", ""], ["예약", "scheduled"], ["활성", "active"], ["만료", "expired"]], params[:license_status]), {}, class: "rounded-lg border px-3 py-2" %>
    <%= form.submit "조회", class: "rounded-lg bg-slate-900 px-4 py-2 font-semibold text-white" %>
  <% end %>
  <div class="mt-6 overflow-x-auto rounded-2xl border bg-white shadow-sm"><table class="min-w-full text-left text-sm"><thead class="bg-slate-50"><tr><th class="p-4">작업</th><th class="p-4">사용자·GitHub</th><th class="p-4">Product·License</th><th class="p-4">Link·Grant</th><th class="p-4">Due</th><th class="p-4">상태</th></tr></thead><tbody class="divide-y"><% @tasks.each do |task| %><tr><td class="p-4"><%= link_to external_task_label(task.task_type), admin_commerce_external_access_task_path(task.public_id), class: "font-semibold text-indigo-700" %></td><td class="p-4"><%= masked_external_access_user(task.external_account_link.user) %><br>@<%= task.external_account_link.username %></td><td class="p-4"><%= task.product&.name || task.external_access_grant&.product&.name || "-" %><br><%= task.license ? "#{task.license.starts_on}~#{task.license.last_usable_on}" : "-" %></td><td class="p-4"><%= task.external_account_link.status %><br><%= task.external_access_grant&.status || "-" %></td><td class="p-4"><%= task.due_at %><br><% if ExternalAccessTask::OPEN_STATUSES.include?(task.status) %><span class="font-semibold <%= task.overdue? ? 'text-red-700' : 'text-slate-500' %>"><%= task.overdue? ? "overdue" : "due" %></span><% else %><span class="font-semibold text-slate-500">처리 완료</span><% end %></td><td class="p-4"><%= task.status %><% if task.reason_code %><br><%= task.reason_code %><% end %></td></tr><% end %></tbody></table></div>
</main></div>
