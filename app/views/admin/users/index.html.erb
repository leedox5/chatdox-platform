<% content_for :title, "사용자관리 - Chatdox" %>

<div class="min-h-screen bg-gray-50">
  <%= render "shared/header" %>

  <main class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
    <header class="mb-8">
      <p class="text-sm font-semibold uppercase tracking-wide text-blue-600">Admin</p>
      <h1 class="mt-1 text-3xl font-bold text-gray-900">사용자관리</h1>
      <p class="mt-2 text-gray-600">사용자 계정, 권한, 구독 상태를 확인합니다.</p>
    </header>

    <section class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 text-sm">
          <thead class="bg-gray-50 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">
            <tr>
              <th class="px-5 py-3">사용자</th>
              <th class="px-5 py-3">권한</th>
              <th class="px-5 py-3">구독</th>
              <th class="px-5 py-3">가입일</th>
              <th class="px-5 py-3 text-right">관리</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @users.each do |user| %>
              <tr>
                <td class="px-5 py-4">
                  <p class="font-medium text-gray-900"><%= user.name %></p>
                  <p class="text-xs text-gray-500"><%= user.email %> · ID <%= user.id %></p>
                </td>
                <td class="px-5 py-4 text-gray-700"><%= user.role %></td>
                <td class="px-5 py-4">
                  <%= subscription_badge(user) %>
                </td>
                <td class="px-5 py-4 text-gray-600">
                  <%= I18n.l(user.created_at.to_date, format: :long, locale: :ko) %>
                </td>
                <td class="px-5 py-4">
                  <%= form_with model: [:admin, user],
                    method: :patch,
                    class: "flex items-center justify-end gap-2" do |form| %>
                    <%= form.select :role,
                      User.roles.keys.map { |role| [role, role] },
                      {},
                      class: "rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
                    <%= form.submit "저장",
                      class: "rounded-lg bg-gray-900 px-3 py-2 text-sm font-semibold text-white transition hover:bg-gray-800" %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</div>
