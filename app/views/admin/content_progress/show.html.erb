<% content_for :title, "콘텐츠 진행 현황 - 관리자" %>

<div class="min-h-screen bg-gray-50">
  <%= render "shared/header" %>

  <main class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
    <header class="mb-8">
      <p class="text-sm font-semibold uppercase tracking-wide text-blue-600">Admin</p>
      <h1 class="mt-1 text-3xl font-bold text-gray-900">콘텐츠 진행 현황</h1>
      <p class="mt-2 text-gray-600">Chatdox·Claudox 두 상품의 문서 작성 진행률을 확인합니다.</p>
    </header>

    <section class="mb-8 grid gap-4 sm:grid-cols-2">
      <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
        <div class="flex items-baseline justify-between">
          <p class="text-sm font-semibold text-gray-500">Chatdox</p>
          <p class="text-2xl font-bold text-gray-900"><%= @chatdox_percent %>%</p>
        </div>
        <div class="mt-3 h-2 overflow-hidden rounded-full bg-gray-100">
          <div class="h-full rounded-full bg-blue-600" style="width: <%= @chatdox_percent %>%"></div>
        </div>
        <p class="mt-2 text-xs text-gray-500"><%= @chatdox_done_count %> / <%= @chatdox_chapters.size %>개 챕터 작성됨</p>
      </div>

      <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
        <div class="flex items-baseline justify-between">
          <p class="text-sm font-semibold text-gray-500">Claudox</p>
          <p class="text-2xl font-bold text-gray-900"><%= @claudox_percent %>%</p>
        </div>
        <div class="mt-3 h-2 overflow-hidden rounded-full bg-gray-100">
          <div class="h-full rounded-full bg-blue-600" style="width: <%= @claudox_percent %>%"></div>
        </div>
        <p class="mt-2 text-xs text-gray-500"><%= @claudox_done_count %> / <%= @claudox_chapters.size %>개 챕터 완료</p>
      </div>
    </section>

    <section class="grid gap-8 lg:grid-cols-2">
      <%= render "product_card", title: "Chatdox", done_count: @chatdox_done_count, chapters: @chatdox_chapters, phases: @chatdox_phases %>
      <%= render "product_card", title: "Claudox", done_count: @claudox_done_count, chapters: @claudox_chapters, phases: @claudox_phases %>
    </section>
  </main>
</div>
