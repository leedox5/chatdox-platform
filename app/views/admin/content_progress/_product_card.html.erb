<article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
  <div class="flex items-center justify-between gap-4">
    <h2 class="text-lg font-bold text-gray-900"><%= title %></h2>
    <span class="rounded-full bg-blue-100 px-3 py-1 text-sm font-semibold text-blue-700">
      <%= done_count %> / <%= chapters.size %>
    </span>
  </div>

  <div class="mt-4 space-y-5">
    <% phases.each do |phase| %>
      <div>
        <div class="mb-2 flex items-baseline justify-between">
          <h3 class="text-sm font-semibold text-gray-700"><%= phase[:label] %> · <%= phase[:title] %></h3>
          <span class="text-xs text-gray-400"><%= phase[:done_count] %>/<%= phase[:chapters].size %></span>
        </div>
        <ul class="divide-y divide-gray-100">
          <% phase[:chapters].each do |chapter| %>
            <li class="flex items-center justify-between gap-4 py-2 text-sm">
              <%= link_to "#{chapter[:id]}. #{chapter[:title]}", chapter[:path], class: "text-gray-700 hover:text-blue-600 hover:underline" %>
              <% if chapter[:done] %>
                <span aria-label="완료">✅</span>
              <% else %>
                <span class="text-gray-300" aria-label="미완료">⬜</span>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </div>
</article>
