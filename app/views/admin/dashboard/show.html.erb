<% content_for :title, "관리자 대시보드 - Chatdox" %>

<div class="min-h-screen bg-gray-50">
  <%= render "shared/header" %>

  <main class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
    <header class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-blue-600">Admin Dashboard</p>
        <h1 class="mt-1 text-3xl font-bold text-gray-900">종합 현황</h1>
        <p class="mt-2 text-gray-600">사용자, 구독, 학습 진행 상태를 빠르게 확인합니다.</p>
      </div>

      <%= link_to "사용자관리",
        admin_users_path,
        class: "rounded-lg bg-blue-600 px-4 py-2.5 text-center font-semibold text-white transition hover:bg-blue-700" %>
    </header>

    <section class="grid gap-5 md:grid-cols-4">
      <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-semibold text-gray-500">전체 사용자</p>
        <p class="mt-3 text-3xl font-bold text-gray-900"><%= @total_users %></p>
      </article>
      <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-semibold text-gray-500">관리자</p>
        <p class="mt-3 text-3xl font-bold text-gray-900"><%= @admin_users %></p>
      </article>
      <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-semibold text-gray-500">활성 구독</p>
        <p class="mt-3 text-3xl font-bold text-gray-900"><%= @active_subscriptions %></p>
      </article>
      <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-semibold text-gray-500">Trial 대상</p>
        <p class="mt-3 text-3xl font-bold text-gray-900"><%= @trial_users %></p>
      </article>
    </section>

    <section class="mt-8 grid gap-8 lg:grid-cols-2">
      <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
        <div class="flex items-center justify-between gap-4">
          <h2 class="text-lg font-bold text-gray-900">최근 가입 사용자</h2>
          <%= link_to "전체 보기", admin_users_path, class: "text-sm font-semibold text-blue-600 hover:text-blue-700" %>
        </div>

        <ul class="mt-4 divide-y divide-gray-100">
          <% @recent_users.each do |user| %>
            <li class="flex items-center justify-between gap-4 py-4">
              <div class="min-w-0">
                <p class="truncate font-medium text-gray-900"><%= user.email %></p>
                <p class="text-sm text-gray-500"><%= I18n.l(user.created_at.to_date, format: :long, locale: :ko) %></p>
              </div>
              <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-700"><%= user.role %></span>
            </li>
          <% end %>
        </ul>
      </article>

      <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-bold text-gray-900">최근 결제 거래</h2>

        <% if @recent_transactions.any? %>
          <ul class="mt-4 divide-y divide-gray-100">
            <% @recent_transactions.each do |transaction| %>
              <li class="flex items-center justify-between gap-4 py-4">
                <div class="min-w-0">
                  <p class="truncate font-medium text-gray-900"><%= transaction.order_id %></p>
                  <p class="text-sm text-gray-500"><%= transaction.provider %> · <%= transaction.currency %> <%= number_with_delimiter(transaction.amount) %></p>
                </div>
                <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-700"><%= transaction.status %></span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="mt-4 rounded-lg bg-gray-50 p-6 text-center text-gray-600">아직 결제 거래가 없습니다.</p>
        <% end %>
      </article>
    </section>
  </main>
</div>
