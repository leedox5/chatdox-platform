# ============================================================
# chatdox-curriculum .gitignore
# 규칙: 이 저장소는 텍스트 기반 문서만 포함합니다.
# 이미지, 바이너리, 빌드 결과물은 Platform 저장소에서 관리합니다.
# ============================================================

# 이미지 파일 (Platform public/images/ 에서 관리)
assets/
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.ico
*.bmp

# 동영상 파일
*.mp4
*.mov
*.avi

# 바이너리/빌드
*.zip
*.tar.gz
*.pdf
dist/
build/
out/

# OS 파일
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# 에디터
.vscode/
.idea/
*.swp
*.swo
*~

# 임시 파일
tmp/
temp/
*.tmp
*.log

# 로그/스크린샷 폴더 (예: service-desk/_screen_shot/), 커밋 대상 아님
_screen_shot/

# 터미널 로그 (호스트명/사용자명 등 개인정보 포함 가능), 커밋 대상 아님
service-desk/_log/

# Tommy 로컬 전용 커맨드/메모, 커밋 대상 아님
.local/

# chatdox-platform/request/ 미러 (로컬 동기화 전용, REQ 0019), 커밋 대상 아님
service-desk/_platform_sync/
